model BlogPost {
  id          String    @id @default(cuid())
  authorId    String    @map("author_id")
  type        PostType  @default(BLOG)
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?
  coverImage  String?   @map("cover_image")
  published   Boolean   @default(false)
  // The "go-live" timestamp. Set when the admin flips published=true,
  // and may be set to a FUTURE date for scheduled posts (Squarespace-
  // style). Public-facing queries filter publishedAt <= now() so a
  // post with a future publishedAt stays hidden from readers but is
  // visible to admins as "scheduled". Cleared when the post is
  // unpublished. Existing rows are backfilled to createdAt by the
  // 20260501 migration so historical posts don't disappear.
  publishedAt DateTime? @map("published_at")
  showAuthor  Boolean   @default(true) @map("show_author")
  viewCount   Int       @default(0) @map("view_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author         User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media          BlogPostMedia[]
  people         BlogPostPerson[]
  twoThumbsVotes TwoThumbsVote[]

  @@map("blog_posts")
}

// User votes on Two Thumbs (PUNCH_AND_JUDY) blog posts — which side
// (thumbs up = positive take, thumbs down = negative take) the reader
// agrees with after reading. Mirrors the forum debate vote shape but
// scoped to BlogPost rows since Two Thumbs lives in the blog system.
model TwoThumbsVote {
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  vote      String // "up" | "down"
  createdAt DateTime @default(now()) @map("created_at")

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("two_thumbs_votes")
}

model BlogPostMedia {
  id         String  @id @default(cuid())
  postId     String  @map("post_id")
  movieId    String? @map("movie_id")
  tvShowId   String? @map("tv_show_id")
  tmdbId     Int     @map("tmdb_id")
  mediaType  String  @map("media_type") // "movie" | "tv"
  title      String
  posterPath String? @map("poster_path")

  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  movie  Movie?   @relation(fields: [movieId], references: [id])
  tvShow TVShow?  @relation(fields: [tvShowId], references: [id])

  @@map("blog_post_media")
}

model BlogPostPerson {
  id          String  @id @default(cuid())
  postId      String  @map("post_id")
  celebrityId String? @map("celebrity_id")
  tmdbId      Int     @map("tmdb_id")
  name        String
  profilePath String? @map("profile_path")

  post      BlogPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  celebrity Celebrity? @relation(fields: [celebrityId], references: [id])

  @@map("blog_post_people")
}

// BlogComment removed — replaced by unified Comment model with targetType="blog"

// Punch & Judy — structured debate per movie
model PunchAndJudyDebate {
  id         String   @id @default(cuid())
  movieId    Int      @unique @map("movie_id") // TMDB id (no FK, avoids requiring movie in DB)
  movieTitle String   @map("movie_title")
  posterPath String?  @map("poster_path")
  createdAt  DateTime @default(now()) @map("created_at")

  arguments PunchAndJudyArgument[]
  votes     PunchAndJudyOverallVote[]

  @@map("punch_and_judy_debates")
}

model PunchAndJudyArgument {
  id        String   @id @default(cuid())
  debateId  String   @map("debate_id")
  authorId  String   @map("author_id")
  side      String // "for" | "against"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  debate   PunchAndJudyDebate    @relation(fields: [debateId], references: [id], onDelete: Cascade)
  author   User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  helpfuls PunchAndJudyHelpful[]

  @@map("punch_and_judy_arguments")
}

model PunchAndJudyHelpful {
  userId     String @map("user_id")
  argumentId String @map("argument_id")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  argument PunchAndJudyArgument @relation(fields: [argumentId], references: [id], onDelete: Cascade)

  @@id([userId, argumentId])
  @@map("punch_and_judy_helpfuls")
}

model PunchAndJudyOverallVote {
  userId   String @map("user_id")
  debateId String @map("debate_id")
  verdict  String // "for" | "against"

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  debate PunchAndJudyDebate @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@id([userId, debateId])
  @@map("punch_and_judy_overall_votes")
}

// Forums
model ForumThread {
  id               String    @id @default(cuid())
  authorId         String    @map("author_id")
  title            String
  slug             String    @unique
  threadType       String    @default("discussion") @map("thread_type") // "discussion" | "theory" | "poll" | "recommendation" | "debate"
  hasSpoilers      Boolean   @default(false) @map("has_spoilers")
  isPinned         Boolean   @default(false) @map("is_pinned")
  isLocked         Boolean   @default(false) @map("is_locked")
  viewCount        Int       @default(0) @map("view_count")
  opponentId       String?   @map("opponent_id") // debate threads: open challenge, anyone can claim
  opponentJoinedAt DateTime? @map("opponent_joined_at") // when the challenger accepted
  bootedUserIds    String[]  @default([]) @map("booted_user_ids") // users who were booted from this debate
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  author      User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  opponent    User?               @relation("forumDebateOpponent", fields: [opponentId], references: [id], onDelete: SetNull)
  posts       ForumPost[]
  media       ForumThreadMedia[]
  people      ForumThreadPerson[]
  tags        ForumThreadTag[]
  poll        ForumPoll?
  debateVotes ForumDebateVote[]
  followers   ForumThreadFollow[]
  views       ForumThreadView[]

  @@index([threadType])
  @@index([createdAt])
  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  isEdited  Boolean  @default(false) @map("is_edited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread    ForumThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions ForumReaction[]

  @@index([threadId, createdAt])
  @@map("forum_posts")
}

model ForumThreadMedia {
  id         String  @id @default(cuid())
  threadId   String  @map("thread_id")
  movieId    String? @map("movie_id")
  tvShowId   String? @map("tv_show_id")
  tmdbId     Int     @map("tmdb_id")
  mediaType  String  @map("media_type") // "movie" | "tv"
  title      String
  posterPath String? @map("poster_path")

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  movie  Movie?      @relation(fields: [movieId], references: [id])
  tvShow TVShow?     @relation(fields: [tvShowId], references: [id])

  @@map("forum_thread_media")
}

model ForumThreadPerson {
  id          String  @id @default(cuid())
  threadId    String  @map("thread_id")
  celebrityId String? @map("celebrity_id")
  tmdbId      Int     @map("tmdb_id")
  name        String
  profilePath String? @map("profile_path")

  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  celebrity Celebrity?  @relation(fields: [celebrityId], references: [id])

  @@map("forum_thread_people")
}

model ForumThreadTag {
  id       String @id @default(cuid())
  threadId String @map("thread_id")
  tag      String

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@map("forum_thread_tags")
}

model ForumReaction {
  id           String @id @default(cuid())
  postId       String @map("post_id")
  userId       String @map("user_id")
  reactionType String @map("reaction_type") // "great-take" | "mind-blown" | "disagree" | "funny"

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, reactionType])
  @@map("forum_reactions")
}

model ForumPoll {
