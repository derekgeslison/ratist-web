generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostType {
  BLOG
  PUNCH_AND_JUDY
  MOVIE_MAP
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique @map("firebase_uid")
  name        String
  email       String   @unique
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  isPrivate   Boolean  @default(false) @map("is_private")
  publicTabs  Json     @default("{\"overview\":true,\"ratings\":true,\"diary\":true,\"watchlist\":true,\"stats\":true,\"rankings\":true}") @map("public_tabs")
  inviteCode  String   @unique @map("invite_code")
  isAdmin     Boolean  @default(false) @map("is_admin")
  isOwner     Boolean  @default(false) @map("is_owner")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  ratings        MovieRating[]
  tvShowRatings  TVShowRating[]
  profile        UserProfile?
  favoriteMovies UserFavoriteMovie[]
  favoriteShows  UserFavoriteShow[]
  episodesSeen   EpisodeSeen[]
  watchlistsOwned  Watchlist[]
  watchlistCollab  WatchlistCollaborator[]
  blogPosts      BlogPost[]
  comments         Comment[]
  commentLikes     CommentLike[]
  postLikes        PostLike[]
  notifications    Notification[]    @relation("notifications")
  notificationsOut Notification[]    @relation("notificationActor")
  pjArguments    PunchAndJudyArgument[]
  pjHelpfuls     PunchAndJudyHelpful[]
  pjVotes        PunchAndJudyOverallVote[]
  forumThreads   ForumThread[]
  forumPosts     ForumPost[]
  looksLikes     LooksLike[]
  looksLikeVotes LooksLikeVote[]
  oscarVotes     OscarVote[]
  recasts        Recast[]
  recastVotes    RecastVote[]
  hotTakes       HotTake[]
  hotTakeVotes   HotTakeVote[]
  moviePitches     MoviePitch[]
  moviePitchVotes  MoviePitchVote[]
  cineqAttempts    CineQAttempt[]
  movieClubMember       MovieClubMember?
  movieClubRatings      MovieClubRating[]
  movieClubNominations  MovieClubNomination[]
  movieClubNomVotes     MovieClubNominationVote[]
  screeningSessionsHosted  ScreeningSession[]       @relation("screeningHost")
  screeningParticipations  ScreeningParticipant[]
  screeningPredictions     ScreeningPrediction[]
  screeningPolls           ScreeningPoll[]
  screeningBookmarks       ScreeningBookmark[]
  screeningChatHighlights  ScreeningChatHighlight[]
  screeningRatings         ScreeningRating[]
  watchLog       UserWatchLog[]
  rankings       UserMovieRanking[]
  rankingLists   UserRankingList[]
  autoDateOnSeen    Boolean  @default(false) @map("auto_date_on_seen")
  notificationPrefs Json     @default("{\"commentOnContent\":true,\"likeOnContent\":true,\"commentReplies\":true,\"commentLikes\":true,\"milestones\":true,\"watchlistInvites\":true}") @map("notification_prefs")

  reportsMade      Report[]  @relation("reportsMade")
  reportsResolved  Report[]  @relation("reportsResolved")
  adminLogs        AdminLog[] @relation("adminLogs")
  followers        UserFollow[] @relation("following")
  following        UserFollow[] @relation("followers")

  // Soft delete
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by") // "self" or admin user ID

  // Ban/block
  bannedAt    DateTime? @map("banned_at")
  bannedUntil DateTime? @map("banned_until") // null = permanent ban
  banReason   String?   @map("ban_reason")

  @@map("users")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("site_config")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // Component preferences (0-10)
  narrativeFocused      Float @default(0) @map("narrative_focused")
  characterFocused      Float @default(0) @map("character_focused")
  messageFocused        Float @default(0) @map("message_focused")
  cinematicFocused      Float @default(0) @map("cinematic_focused")
  performanceFocused    Float @default(0) @map("performance_focused")
  entertainmentFocused  Float @default(0) @map("entertainment_focused")

  // Genre preferences (0-10)
  genreAction        Float @default(0) @map("genre_action")
  genreHorror        Float @default(0) @map("genre_horror")
  genreDrama         Float @default(0) @map("genre_drama")
  genreHistorical    Float @default(0) @map("genre_historical")
  genreScifi         Float @default(0) @map("genre_scifi")
  genreThriller      Float @default(0) @map("genre_thriller")
  genreComedy        Float @default(0) @map("genre_comedy")
  genreBookAdapt     Float @default(0) @map("genre_book_adaptation")
  genreFantasy       Float @default(0) @map("genre_fantasy")
  genreRomance       Float @default(0) @map("genre_romance")
  genreDocumentary   Float @default(0) @map("genre_documentary")
  genreFamily        Float @default(0) @map("genre_family")
  genreFilmNoir      Float @default(0) @map("genre_film_noir")
  genreMusical       Float @default(0) @map("genre_musical")
  genreBiopic        Float @default(0) @map("genre_biopic")
  genreCrime         Float @default(0) @map("genre_crime")
  genreWestern       Float @default(0) @map("genre_western")
  genreMystery       Float @default(0) @map("genre_mystery")

  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Movie {
  id           String   @id @default(cuid())
  tmdbId       Int      @unique @map("tmdb_id")
  title        String
  overview     String?
  posterPath   String?  @map("poster_path")
  backdropPath String?  @map("backdrop_path")
  releaseDate  String?  @map("release_date")
  runtime      Int?
  mpaaRating   String?  @map("mpaa_rating")
  tagline      String?
  budget       BigInt?
  revenue      BigInt?
  popularity   Float?
  voteAverage  Float?   @map("vote_average")
  voteCount    Int?     @map("vote_count")
  trailerKey   String?  @map("trailer_key")
  status       String?
  watchProviders    Json?     @map("watch_providers") // { flatrate: [{name, logo}], rent: [{name, logo}] }
  providersUpdatedAt DateTime? @map("providers_updated_at")
  cachedAt     DateTime? @map("cached_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  genres      MovieGenre[]
  cast        MovieCast[]
  ratings     MovieRating[]
  favoritedBy UserFavoriteMovie[]
  watchLog    UserWatchLog[]
  watchlistEntries WatchlistMovie[]
  rankings         UserMovieRanking[]
  movieClubWeeks   MovieClubWeek[]
  screeningSessions ScreeningSession[]

  @@map("movies")
}

model Genre {
  id     Int    @id
  name   String @unique
  movies MovieGenre[]
  tvShows TVShowGenre[]

  @@map("genres")
}

model MovieGenre {
  movieId String @map("movie_id")
  genreId Int    @map("genre_id")

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@map("movie_genres")
}

model Celebrity {
  id                 String    @id @default(cuid())
  tmdbId             Int       @unique @map("tmdb_id")
  name               String
  profilePath        String?   @map("profile_path")
  knownForDepartment String?   @map("known_for_department")
  knownFor           String?   @map("known_for")
  birthday           String?
  deathday           String?
  placeOfBirth       String?   @map("place_of_birth")
  biography          String?   @db.Text
  popularity         Float?
  cachedAt           DateTime? @map("cached_at")

  movieRoles MovieCast[]
  tvShowRoles TVShowCast[]

  @@map("celebrities")
}

model MovieCast {
  id          String  @id @default(cuid())
  movieId     String  @map("movie_id")
  celebrityId String  @map("celebrity_id")
  creditType  String  @default("cast") @map("credit_type") // "cast" | "crew"
  character   String?
  job         String  @default("") // crew: "Director", "Writer", etc. Empty string for cast.
  department  String? // crew: "Directing", "Writing", etc.
  castOrder   Int     @default(0) @map("cast_order")

  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)

  @@unique([movieId, celebrityId, creditType, job])
  @@map("movie_cast")
}

// ─── TV Shows ─────────────────────────────────────────────────────────────────

model TVShow {
  id             String   @id @default(cuid())
  tmdbId         Int      @unique @map("tmdb_id")
  name           String
  overview       String?  @db.Text
  posterPath     String?  @map("poster_path")
  backdropPath   String?  @map("backdrop_path")
  firstAirDate   String?  @map("first_air_date")
  lastAirDate    String?  @map("last_air_date")
  status         String?  // "Returning Series", "Ended", "Canceled", etc.
  numberOfSeasons  Int?   @map("number_of_seasons")
  numberOfEpisodes Int?   @map("number_of_episodes")
  episodeRunTime   Int?   @map("episode_run_time") // avg minutes
  contentRating    String? @map("content_rating") // TV-Y, TV-G, TV-PG, TV-14, TV-MA
  tagline        String?
  popularity     Float?
  voteAverage    Float?   @map("vote_average")
  voteCount      Int?     @map("vote_count")
  trailerKey     String?  @map("trailer_key")
  networks       Json?    // [{ id, name, logo_path }]
  watchProviders    Json?     @map("watch_providers")
  providersUpdatedAt DateTime? @map("providers_updated_at")
  cachedAt       DateTime? @map("cached_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  genres     TVShowGenre[]
  cast       TVShowCast[]
  seasons    TVSeason[]
  ratings    TVShowRating[]
  favoritedBy UserFavoriteShow[]
  watchlistEntries WatchlistShow[]
  rankings         UserMovieRanking[]

  @@map("tv_shows")
}

model TVSeason {
  id            String   @id @default(cuid())
  tvShowId      String   @map("tv_show_id")
  tmdbId        Int      @map("tmdb_id") // TMDB season ID
  seasonNumber  Int      @map("season_number")
  name          String?
  overview      String?  @db.Text
  posterPath    String?  @map("poster_path")
  airDate       String?  @map("air_date")
  episodeCount  Int?     @map("episode_count")
  voteAverage   Float?   @map("vote_average")

  tvShow   TVShow      @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  episodes TVEpisode[]

  @@unique([tvShowId, seasonNumber])
  @@map("tv_seasons")
}

model TVEpisode {
  id            String   @id @default(cuid())
  seasonId      String   @map("season_id")
  tmdbId        Int      @map("tmdb_id") // TMDB episode ID
  episodeNumber Int      @map("episode_number")
  name          String?
  overview      String?  @db.Text
  stillPath     String?  @map("still_path") // episode screenshot
  airDate       String?  @map("air_date")
  runtime       Int?
  voteAverage   Float?   @map("vote_average")
  voteCount     Int?     @map("vote_count")

  season TVSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, episodeNumber])
  @@map("tv_episodes")
}

model TVShowGenre {
  tvShowId String @map("tv_show_id")
  genreId  Int    @map("genre_id")

  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  genre  Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([tvShowId, genreId])
  @@map("tv_show_genres")
}

model TVShowCast {
  id          String  @id @default(cuid())
  tvShowId    String  @map("tv_show_id")
  celebrityId String  @map("celebrity_id")
  creditType  String  @default("cast") @map("credit_type") // "cast" | "crew"
  character   String?
  job         String  @default("")
  department  String?
  castOrder   Int     @default(0) @map("cast_order")
  episodeCount Int?   @map("episode_count") // how many episodes they appeared in

  tvShow    TVShow    @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)

  @@unique([tvShowId, celebrityId, creditType, job])
  @@map("tv_show_cast")
}

model UserFavoriteShow {
  userId    String    @map("user_id")
  tvShowId  String    @map("tv_show_id")
  createdAt DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@id([userId, tvShowId])
  @@map("user_favorite_shows")
}

model EpisodeSeen {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  showTmdbId    Int       @map("show_tmdb_id")
  seasonNumber  Int       @map("season_number")
  episodeNumber Int       @map("episode_number")
  watchedDate   DateTime? @map("watched_date")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, showTmdbId, seasonNumber, episodeNumber])
  @@index([userId, showTmdbId])
  @@index([userId, watchedDate])
  @@map("episode_seen")
}

model WatchlistShow {
  id          String    @id @default(cuid())
  watchlistId String    @map("watchlist_id")
  tvShowId    String    @map("tv_show_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isChecked   Boolean   @default(false) @map("is_checked")
  checkedAt   DateTime? @map("checked_at")
  addedAt     DateTime  @default(now()) @map("added_at")

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  tvShow    TVShow    @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, tvShowId])
  @@map("watchlist_shows")
}

model TVShowRating {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  tvShowId  String @map("tv_show_id")

  // "series" = overall show rating, or a specific season number
  ratingScope   String  @default("series") @map("rating_scope") // "series" | "season"
  seasonNumber  Int     @default(0) @map("season_number") // 0 for series-level, 1+ for seasons

  // Story (weight 5)
  plot               Float?
  premiseOriginality Float? @map("premise_originality")
  storytelling       Float?
  characterDev       Float? @map("character_dev")
  pacingClimax       Float? @map("pacing_climax")

  // Production & Style (weight 3)
  cinematography   Float?
  locationCost     Float? @map("location_costuming")
  realism          Float? @map("realism_believability")
  artisticEffect   Float? @map("artistic_effect")
  visualEffects    Float? @map("visual_effects")
  musicSound       Float? @map("music_sound")

  // Emotive Effect (weight 3)
  overallEmotion Float? @map("overall_emotion")
  relatability   Float?
  meaning        Float?
  movingness     Float?

  // Acting & Casting (weight 3)
  casting            Float?
  actingQuality      Float? @map("acting_quality")
  dialogueScripting  Float? @map("dialogue_scripting")
  blockingChoreo     Float? @map("blocking_choreography")

  // Pure Entertainment (weight 2)
  appeal            Float?
  superficialAllure Float? @map("superficial_allure")
  choreography      Float?

  // Optional overall
  overallRating Float? @map("overall_rating")

  // Cached computed scores
  storyScore        Float? @map("story_score")
  styleScore        Float? @map("style_score")
  emotiveScore      Float? @map("emotive_score")
  actingScore       Float? @map("acting_score")
  entertainScore    Float? @map("entertainment_score")
  ratistRating      Float? @map("ratist_rating")

  reviewText       String?  @map("review_text")
  reviewType       String   @default("standard") @map("review_type")
  fieldComments    Json?    @map("field_comments")
  categoryComments Json?    @map("category_comments")
  hasSpoilers      Boolean  @default(false) @map("has_spoilers")
  commentsDisabled Boolean  @default(false) @map("comments_disabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@unique([userId, tvShowId, ratingScope, seasonNumber])
  @@map("tv_show_ratings")
}

model MovieRating {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  movieId String @map("movie_id")

  // Story (weight 5) — required: plot, storytelling, pacingClimax
  plot               Float?
  premiseOriginality Float? @map("premise_originality")
  storytelling       Float?
  characterDev       Float? @map("character_dev")
  pacingClimax       Float? @map("pacing_climax")

  // Production & Style (weight 3) — required: cinematography, artisticEffect
  cinematography   Float?
  locationCost     Float? @map("location_costuming")
  realism          Float? @map("realism_believability")
  artisticEffect   Float? @map("artistic_effect")
  visualEffects    Float? @map("visual_effects")
  musicSound       Float? @map("music_sound")

  // Emotive Effect (weight 3) — required: overallEmotion, relatability
  overallEmotion Float? @map("overall_emotion")
  relatability   Float?
  meaning        Float?
  movingness     Float?

  // Acting & Casting (weight 3) — required: casting (Casting & Subjects), actingQuality (Performance Quality)
  casting            Float?
  actingQuality      Float? @map("acting_quality")
  dialogueScripting  Float? @map("dialogue_scripting")
  blockingChoreo     Float? @map("blocking_choreography")

  // Pure Entertainment (weight 2) — required: appeal
  appeal            Float?
  superficialAllure Float? @map("superficial_allure") // excluded from score
  choreography      Float?

  // Optional overall
  overallRating Float? @map("overall_rating")

  // Genre accuracy (optional)
  genreAction      Float? @map("genre_action")
  genreHorror      Float? @map("genre_horror")
  genreDrama       Float? @map("genre_drama")
  genreHistorical  Float? @map("genre_historical")
  genreScifi       Float? @map("genre_scifi")
  genreThriller    Float? @map("genre_thriller")
  genreComedy      Float? @map("genre_comedy")
  genreBookAdapt   Float? @map("genre_book_adaptation")
  genreFantasy     Float? @map("genre_fantasy")
  genreRomance     Float? @map("genre_romance")
  genreDocumentary Float? @map("genre_documentary")
  genreFamily      Float? @map("genre_family")
  genreFilmNoir    Float? @map("genre_film_noir")
  genreMusical     Float? @map("genre_musical")
  genreBiopic      Float? @map("genre_biopic")
  genreCrime       Float? @map("genre_crime")
  genreWestern     Float? @map("genre_western")
  genreMystery     Float? @map("genre_mystery")

  // Cached computed scores
  storyScore        Float? @map("story_score")
  styleScore        Float? @map("style_score")
  emotiveScore      Float? @map("emotive_score")
  actingScore       Float? @map("acting_score")
  entertainScore    Float? @map("entertainment_score")
  ratistRating      Float? @map("ratist_rating")

  reviewText   String?  @map("review_text")
  importSource     String?  @map("import_source") // "letterboxd" | "imdb" | "trakt" etc.
  reviewType       String   @default("standard") @map("review_type") // "basic" | "standard" | "critic"
  fieldComments    Json?    @map("field_comments") // critic mode: { "plot": "comment", ... }
  categoryComments Json?    @map("category_comments") // critic mode: { "story": "comment", ... }
  hasSpoilers      Boolean  @default(false) @map("has_spoilers")
  commentsDisabled Boolean  @default(false) @map("comments_disabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("movie_ratings")
}

// ─── Unified Comments & Likes ─────────────────────────────────────────────────

model Comment {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  targetType String    @map("target_type") // "review" | "blog" | "lookslike" | "recast" | "hottake" | "oscar_category"
  targetId   String    @map("target_id")
  parentId   String?   @map("parent_id")
  text       String
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("CommentThread")
  likes   CommentLike[]

  @@index([targetType, targetId])
  @@map("comments")
}

model CommentLike {
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("comment_likes")
}

model PostLike {
  userId     String   @map("user_id")
  targetType String   @map("target_type") // "blog"
  targetId   String   @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, targetType, targetId])
  @@map("post_likes")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  type       String   // "comment" | "reply" | "comment_like" | "post_like" | "milestone" | "watchlist_invite" | "invite_accepted"
  actorId    String?  @map("actor_id")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  link       String?  // URL to navigate to when clicked
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user  User  @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, type, targetType, targetId])
  @@map("notifications")
}

model UserFavoriteMovie {
  userId      String    @map("user_id")
  movieId     String    @map("movie_id")
  watchedDate DateTime? @map("watched_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([userId, movieId])
  @@map("user_favorite_movies")
}

model UserWatchLog {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  movieId     String    @map("movie_id")
  watchedDate DateTime? @map("watched_date")
  notes       String?
  isRewatch   Boolean   @default(false) @map("is_rewatch")
  createdAt   DateTime  @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("user_watch_log")
}

model UserMovieRanking {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  movieId   String? @map("movie_id")
  tvShowId  String? @map("tv_show_id")
  listKey   String  @default("all-time") @map("list_key") // "all-time" | "2024" | "2025" | "custom-..." etc.
  sortOrder Int     @map("sort_order")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie  Movie?  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  tvShow TVShow? @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId, listKey])
  @@unique([userId, tvShowId, listKey])
  @@map("user_movie_rankings")
}

model UserRankingList {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  listKey   String   @map("list_key") // used as listKey in UserMovieRanking
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listKey])
  @@map("user_ranking_lists")
}

model Watchlist {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  slug        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isPrivate   Boolean  @default(false) @map("is_private")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  movies        WatchlistMovie[]
  shows         WatchlistShow[]
  collaborators WatchlistCollaborator[]

  @@unique([userId, slug])
  @@map("watchlists")
}

model WatchlistMovie {
  id          String    @id @default(cuid())
  watchlistId String    @map("watchlist_id")
  movieId     String    @map("movie_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isChecked   Boolean   @default(false) @map("is_checked")
  checkedAt   DateTime? @map("checked_at")
  addedAt     DateTime  @default(now()) @map("added_at")

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, movieId])
  @@map("watchlist_movies")
}

model WatchlistCollaborator {
  watchlistId String   @map("watchlist_id")
  userId      String   @map("user_id")
  role        String   @default("editor") // "editor" | "viewer"
  status      String   @default("pending") // "pending" | "accepted"
  addedAt     DateTime @default(now()) @map("added_at")

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([watchlistId, userId])
  @@map("watchlist_collaborators")
}

model BlogPost {
  id         String   @id @default(cuid())
  authorId   String   @map("author_id")
  type       PostType @default(BLOG)
  title      String
  slug       String   @unique
  content    String   @db.Text
  excerpt    String?
  coverImage String?  @map("cover_image")
  published  Boolean  @default(false)
  showAuthor Boolean  @default(true) @map("show_author")
  viewCount  Int      @default(0) @map("view_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("blog_posts")
}

// BlogComment removed — replaced by unified Comment model with targetType="blog"

// Punch & Judy — structured debate per movie
model PunchAndJudyDebate {
  id        String   @id @default(cuid())
  movieId   Int      @unique @map("movie_id") // TMDB id (no FK, avoids requiring movie in DB)
  movieTitle String  @map("movie_title")
  posterPath String? @map("poster_path")
  createdAt DateTime @default(now()) @map("created_at")

  arguments PunchAndJudyArgument[]
  votes     PunchAndJudyOverallVote[]

  @@map("punch_and_judy_debates")
}

model PunchAndJudyArgument {
  id        String   @id @default(cuid())
  debateId  String   @map("debate_id")
  authorId  String   @map("author_id")
  side      String   // "for" | "against"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  debate    PunchAndJudyDebate  @relation(fields: [debateId], references: [id], onDelete: Cascade)
  author    User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  helpfuls  PunchAndJudyHelpful[]

  @@map("punch_and_judy_arguments")
}

model PunchAndJudyHelpful {
  userId     String @map("user_id")
  argumentId String @map("argument_id")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  argument PunchAndJudyArgument @relation(fields: [argumentId], references: [id], onDelete: Cascade)

  @@id([userId, argumentId])
  @@map("punch_and_judy_helpfuls")
}

model PunchAndJudyOverallVote {
  userId   String @map("user_id")
  debateId String @map("debate_id")
  verdict  String // "for" | "against"

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  debate PunchAndJudyDebate @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@id([userId, debateId])
  @@map("punch_and_judy_overall_votes")
}

// Forums
model ForumCategory {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  description String?
  sortOrder   Int    @default(0) @map("sort_order")

  threads ForumThread[]

  @@map("forum_categories")
}

model ForumThread {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  authorId   String   @map("author_id")
  title      String
  slug       String   @unique
  isPinned   Boolean  @default(false) @map("is_pinned")
