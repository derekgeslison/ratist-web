generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostType {
  BLOG
  PUNCH_AND_JUDY
  MOVIE_MAP
}

model User {
  id                               String    @id @default(cuid())
  firebaseUid                      String    @unique @map("firebase_uid")
  name                             String
  email                            String    @unique
  avatarUrl                        String?   @map("avatar_url")
  bio                              String?
  isPrivate                        Boolean   @default(false) @map("is_private")
  publicTabs                       Json      @default("{\"overview\":true,\"ratings\":true,\"diary\":true,\"watchlist\":true,\"stats\":true,\"rankings\":true}") @map("public_tabs")
  inviteCode                       String    @unique @map("invite_code")
  isAdmin                          Boolean   @default(false) @map("is_admin")
  isOwner                          Boolean   @default(false) @map("is_owner")
  aiDisabled                       Boolean   @default(false) @map("ai_disabled") // admin-set: blocks all AI features for this user
  // Admin-set: blocks this user from submitting Watch Companion suggestions.
  // Used to shut down troll/low-signal submitters without hard-banning them
  // from the rest of the site.
  companionSuggestionsBlocked      Boolean   @default(false) @map("companion_suggestions_blocked")
  // Optional expiry — when set, the block auto-lifts after this timestamp.
  // Null means the block is permanent (until admin unblocks manually).
  companionSuggestionsBlockedUntil DateTime? @map("companion_suggestions_blocked_until")
  createdAt                        DateTime  @default(now()) @map("created_at")
  updatedAt                        DateTime  @updatedAt @map("updated_at")
  onboardedAt                      DateTime? @map("onboarded_at")
  // Set when the user dismisses the home tour banner OR visits /welcome.
  // Persisted server-side so the dismissal sticks across devices and
  // through localStorage clears. Null = banner still active.
  tourDismissedAt                  DateTime? @map("tour_dismissed_at")

  // Per-user concurrency lock for Watch Companion generation. Set
  // when a gen request starts, cleared when it finishes (or after a
  // 10-minute TTL fallback so an interrupted gen doesn't lock the
  // user out forever). One in-flight gen per user prevents a single
  // user from fanning out parallel requests.
  companionGenStartedAt            DateTime? @map("companion_gen_started_at")

  ratings                       MovieRating[]
  tvShowRatings                 TVShowRating[]
  profile                       UserProfile?
  favoriteMovies                UserFavoriteMovie[]
  favoriteShows                 UserFavoriteShow[]
  episodesSeen                  EpisodeSeen[]
  watchlistsOwned               Watchlist[]
  watchlistCollab               WatchlistCollaborator[]
  blogPosts                     BlogPost[]
  newsItems                     NewsItem[]
  comments                      Comment[]
  commentLikes                  CommentLike[]
  postLikes                     PostLike[]
  notifications                 Notification[]            @relation("notifications")
  notificationsOut              Notification[]            @relation("notificationActor")
  pjArguments                   PunchAndJudyArgument[]
  pjHelpfuls                    PunchAndJudyHelpful[]
  pjVotes                       PunchAndJudyOverallVote[]
  forumThreads                  ForumThread[]
  forumPosts                    ForumPost[]
  forumReactions                ForumReaction[]
  forumPollVotes                ForumPollVote[]
  forumDebateVotes              ForumDebateVote[]
  twoThumbsVotes                TwoThumbsVote[]
  forumDebateOpponent           ForumThread[]             @relation("forumDebateOpponent")
  forumThreadFollows            ForumThreadFollow[]
  forumThreadViews              ForumThreadView[]
  looksLikes                    LooksLike[]
  looksLikeVotes                LooksLikeVote[]
  oscarVotes                    OscarVote[]
  oscarSuggestions              OscarSuggestion[]         @relation("oscarSuggestions")
  oscarSuggestionSeconds        OscarSuggestionSecond[]
  recasts                       Recast[]
  recastVotes                   RecastVote[]
  hotTakes                      HotTake[]
  hotTakeVotes                  HotTakeVote[]
  moviePitches                  MoviePitch[]
  moviePitchVotes               MoviePitchVote[]
  cineqAttempts                 CineQAttempt[]
  movieClubMember               MovieClubMember?
  movieClubRatings              MovieClubRating[]
  movieClubNominations          MovieClubNomination[]
  movieClubNomVotes             MovieClubNominationVote[]
  movieClubRewatchPolls         MovieClubRewatchPoll[]
  movieClubReactions            MovieClubReviewReaction[]
  screeningSessionsHosted       ScreeningSession[]        @relation("screeningHost")
  screeningParticipations       ScreeningParticipant[]
  screeningPredictions          ScreeningPrediction[]
  screeningPolls                ScreeningPoll[]
  screeningBookmarks            ScreeningBookmark[]
  screeningChatHighlights       ScreeningChatHighlight[]
  screeningRatings              ScreeningRating[]
  watchLog                      UserWatchLog[]
  rankings                      UserMovieRanking[]
  rankingLists                  UserRankingList[]
  autoDateOnSeen                Boolean                   @default(false) @map("auto_date_on_seen")
  autoSeenOnWatchlistCheck      Boolean                   @default(false) @map("auto_seen_on_watchlist_check")
  // Watchlist settings — surfaced via the gear icon on /watchlist.
  // autoAddToDefaultWatchlist: when true, tapping the watchlist button
  //   on cards / detail pages auto-adds to the user's default
  //   watchlist before opening the picker. Default true preserves
  //   the existing one-tap-to-add UX for solo-list users.
  // autoRemoveFromWatchlistOnSeen: when set, marking a movie/show as
  //   seen also removes it from "all" watchlists or just the
  //   "default" watchlist. "none" disables.
  // defaultWatchlistFilter: which filter the /watchlist page lands
  //   on by default ("all" or "unwatched").
  // watchlistAddPosition: "top" | "bottom" — where new entries land
  //   in the custom sortOrder when added to a list.
  // pinCheckedToBottom: when true, items checked off (seen) are
  //   secondary-sorted to the bottom of the active sort order on the
  //   watchlist display. Doesn't mutate sortOrder; reorder mode
  //   still shows true custom order.
  autoAddToDefaultWatchlist     Boolean                   @default(true) @map("auto_add_to_default_watchlist")
  autoRemoveFromWatchlistOnSeen String                    @default("none") @map("auto_remove_from_watchlist_on_seen")
  defaultWatchlistFilter        String                    @default("all") @map("default_watchlist_filter")
  watchlistAddPosition          String                    @default("top") @map("watchlist_add_position")
  pinCheckedToBottom            Boolean                   @default(false) @map("pin_checked_to_bottom")
  // Opt-in: notify when a movie/show on any of the user's watchlists
  // becomes available on a big-8 streaming provider. Daily digest —
  // one notification per day max, regardless of how many items launched.
  watchlistStreamingNotifs      Boolean                   @default(false) @map("watchlist_streaming_notifs")
  notificationPrefs             Json                      @default("{\"commentOnContent\":true,\"likeOnContent\":true,\"commentReplies\":true,\"commentLikes\":true,\"milestones\":true,\"watchlistInvites\":true}") @map("notification_prefs")
  emailOptOut                   Boolean                   @default(false) @map("email_opt_out") // legacy — use emailPrefs instead
  emailPrefs                    Json                      @default("{\"promotional\":true,\"subscription\":true,\"activity\":true}") @map("email_prefs")
  forYouOrder                   Json?                     @map("for_you_order") // Array of section keys for For You page ordering
  lastExportAt                  DateTime?                 @map("last_export_at")

  // Backstage Pass subscription
  subscriptionTier     String?   @map("subscription_tier") // null = free, "backstage_pass" = paid
  subscriptionStatus   String?   @map("subscription_status") // "active" | "canceled" | "past_due" | "admin_granted"
  subscriptionExpiry   DateTime? @map("subscription_expiry")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  grantedBy            String?   @map("granted_by") // admin userId who granted manual sub
  grantedPromo         String?   @map("granted_promo") // e.g. "first_1000_reviews"
  promoRemindersSent   Json?     @map("promo_reminders_sent") // array of day thresholds already emailed, e.g. [30, 14]

  // Profile theme customization (Backstage Pass feature)
  profileTheme Json? @map("profile_theme") // { preset?, accentColor?, surfaceColor?, textColor?, headerImage? }

  reportsMade                    Report[]                  @relation("reportsMade")
  reportsResolved                Report[]                  @relation("reportsResolved")
  feedbackSubmitted              Feedback[]                @relation("feedbackSubmitted")
  feedbackReplied                Feedback[]                @relation("feedbackReplied")
  contactsHandled                Contact[]                 @relation("contactHandled")
  inviteCodeRequests             InviteCodeRequest[]       @relation("inviteCodeRequester")
  inviteCodeRequestsResolved     InviteCodeRequest[]       @relation("inviteCodeResolver")
  spotlightDismissals            SpotlightDismissal[]
  ideasSubmitted                 PostIdea[]                @relation("ideasSubmitted")
  ideasReviewed                  PostIdea[]                @relation("ideasReviewed")
  aiUsageLogs                    AiUsageLog[]
  customCollections              CustomCollection[]
  collectionSaves                CollectionSave[]
  collectionPromptsAuthored      CollectionPrompt[]        @relation("CollectionPromptAuthor")
  collectionMatchCache           CollectionMatchCache[]
  adminLogs                      AdminLog[]                @relation("adminLogs")
  followers                      UserFollow[]              @relation("following")
  following                      UserFollow[]              @relation("followers")
  blocksMade                     UserBlock[]               @relation("blocker")
  blocksReceived                 UserBlock[]               @relation("blocked")
  userBadges                     UserBadge[]
  companionsGenerated            WatchCompanion[]          @relation("companionGenerator")
  companionSuggestions           CompanionSuggestion[]     @relation("suggestionAuthor")
  companionSuggestionVotes       CompanionSuggestionVote[]
  companionSuggestionResolutions CompanionSuggestion[]     @relation("suggestionResolver")
  watchCompanionRatings          WatchCompanionRating[]
  companionFollows               CompanionFollow[]
  affiliateClicks                AffiliateClick[]
  streamingWatches               StreamingWatch[]

  // Soft delete
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") // "self" or admin user ID

  // Ban/block
  bannedAt    DateTime? @map("banned_at")
  bannedUntil DateTime? @map("banned_until") // null = permanent ban
  banReason   String?   @map("ban_reason")

  @@map("users")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  // "accepted" = follow is live; the follower can see the followee's
  // protected content and counts toward follower stats.
  // "pending"  = the followee is private and has not yet approved
  // the request; nothing else applies until they accept.
  // Existing rows default to "accepted" so the migration is a no-op
  // for already-active follows.
  status      String   @default("accepted") @map("status")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followingId, status])
  @@map("user_follows")
}

// One-way block: blocker can no longer be followed/seen by blocked,
// and blocked can no longer follow/see blocker. Bi-directionally
// hides the two users from each other's content/search/feeds.
model UserBlock {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // Component preferences (0-10)
  narrativeFocused     Float @default(0) @map("narrative_focused")
  characterFocused     Float @default(0) @map("character_focused")
  messageFocused       Float @default(0) @map("message_focused")
  cinematicFocused     Float @default(0) @map("cinematic_focused")
  performanceFocused   Float @default(0) @map("performance_focused")
  entertainmentFocused Float @default(0) @map("entertainment_focused")

  // Genre preferences (0-10)
  genreAction      Float @default(0) @map("genre_action")
  genreHorror      Float @default(0) @map("genre_horror")
  genreDrama       Float @default(0) @map("genre_drama")
  genreHistorical  Float @default(0) @map("genre_historical")
  genreScifi       Float @default(0) @map("genre_scifi")
  genreThriller    Float @default(0) @map("genre_thriller")
  genreComedy      Float @default(0) @map("genre_comedy")
  genreBookAdapt   Float @default(0) @map("genre_book_adaptation")
  genreFantasy     Float @default(0) @map("genre_fantasy")
  genreRomance     Float @default(0) @map("genre_romance")
  genreDocumentary Float @default(0) @map("genre_documentary")
  genreFamily      Float @default(0) @map("genre_family")
  genreFilmNoir    Float @default(0) @map("genre_film_noir")
  genreMusical     Float @default(0) @map("genre_musical")
  genreBiopic      Float @default(0) @map("genre_biopic")
  genreCrime       Float @default(0) @map("genre_crime")
  genreWestern     Float @default(0) @map("genre_western")
  genreMystery     Float @default(0) @map("genre_mystery")

  // Preserved copy of user's explicit onboarding/settings preferences
  // Used for blending with rating-derived scores until 10 full Ratist ratings
  statedPrefs Json? @map("stated_prefs")

  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Movie {
  id                 String    @id @default(cuid())
  tmdbId             Int       @unique @map("tmdb_id")
  imdbId             String?   @unique @map("imdb_id")
  title              String
  overview           String?
  posterPath         String?   @map("poster_path")
  backdropPath       String?   @map("backdrop_path")
  releaseDate        String?   @map("release_date")
  runtime            Int?
  mpaaRating         String?   @map("mpaa_rating")
  tagline            String?
  budget             BigInt?
  revenue            BigInt?
  popularity         Float?
  voteAverage        Float?    @map("vote_average")
  voteCount          Int?      @map("vote_count")
  trailerKey         String?   @map("trailer_key")
  status             String?
  watchProviders     Json?     @map("watch_providers") // { flatrate: [{name, logo}], rent: [{name, logo}] }
  providersUpdatedAt DateTime? @map("providers_updated_at")
  // TMDB belongs_to_collection — drives franchise aggregations on
  // /box-office/franchises. Stored inline rather than via a separate
  // Collection table; we only need id + name for grouping and label
  // rendering, and TMDB collection metadata is otherwise unused.
  tmdbCollectionId   Int?      @map("tmdb_collection_id")
  tmdbCollectionName String?   @map("tmdb_collection_name")
  // TMDB original_language — ISO 639-1 (e.g. "en", "ko", "fr").
  // Drives the language filter on /box-office/all so users can scope
  // leaderboards to non-English releases without us having to query
  // TMDB Discover at runtime.
  originalLanguage   String?   @map("original_language")
  cachedAt           DateTime? @map("cached_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  genres            MovieGenre[]
  cast              MovieCast[]
  ratings           MovieRating[]
  favoritedBy       UserFavoriteMovie[]
  watchLog          UserWatchLog[]
  watchlistEntries  WatchlistMovie[]
  rankings          UserMovieRanking[]
  movieClubWeeks    MovieClubWeek[]
  screeningSessions ScreeningSession[]
  forumThreadMedia  ForumThreadMedia[]
  newsItemMedia     NewsItemMedia[]
  blogPostMedia     BlogPostMedia[]
  awards            AwardNomination[]   @relation("movieAwards")
  awardForWork      AwardNomination[]   @relation("forWorkMovie")
  studios           MovieStudio[]

  @@index([tmdbCollectionId])
  @@index([originalLanguage])
  @@map("movies")
}

// TMDB production_companies — drives /box-office/studios. Stored
// keyed by TMDB id so the upsert path doesn't need to dedup by
// name (TMDB has duplicate names across regions for some studios,
// but the ids are stable).
model Studio {
  id            Int     @id // TMDB production_company id
  name          String
  logoPath      String? @map("logo_path")
  originCountry String? @map("origin_country")

  movies MovieStudio[]

  @@map("studios")
}

model MovieStudio {
  movieId  String @map("movie_id")
  studioId Int    @map("studio_id")

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@id([movieId, studioId])
  @@index([studioId])
  @@map("movie_studios")
}

model Genre {
  id      Int           @id
  name    String        @unique
  movies  MovieGenre[]
  tvShows TVShowGenre[]

  @@map("genres")
}

model MovieGenre {
  movieId String @map("movie_id")
  genreId Int    @map("genre_id")

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@map("movie_genres")
}

model Celebrity {
  id                 String    @id @default(cuid())
  tmdbId             Int       @unique @map("tmdb_id")
  imdbId             String?   @unique @map("imdb_id")
  name               String
  profilePath        String?   @map("profile_path")
  knownForDepartment String?   @map("known_for_department")
  knownFor           String?   @map("known_for")
  birthday           String?
  deathday           String?
  placeOfBirth       String?   @map("place_of_birth")
  biography          String?   @db.Text
  popularity         Float?
  cachedAt           DateTime? @map("cached_at")

  movieRoles        MovieCast[]
  tvShowRoles       TVShowCast[]
  forumThreadPeople ForumThreadPerson[]
  newsItemPeople    NewsItemPerson[]
  blogPostPeople    BlogPostPerson[]
  awards            AwardNomination[]   @relation("celebrityAwards")

  @@map("celebrities")
}

model MovieCast {
  id          String  @id @default(cuid())
  movieId     String  @map("movie_id")
  celebrityId String  @map("celebrity_id")
  creditType  String  @default("cast") @map("credit_type") // "cast" | "crew"
  character   String?
  job         String  @default("") // crew: "Director", "Writer", etc. Empty string for cast.
  department  String? // crew: "Directing", "Writing", etc.
  castOrder   Int     @default(0) @map("cast_order")

  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)

  @@unique([movieId, celebrityId, creditType, job])
  @@map("movie_cast")
}

// ─── TV Shows ─────────────────────────────────────────────────────────────────

model TVShow {
  id                 String    @id @default(cuid())
  tmdbId             Int       @unique @map("tmdb_id")
  imdbId             String?   @unique @map("imdb_id")
  name               String
  overview           String?   @db.Text
  posterPath         String?   @map("poster_path")
  backdropPath       String?   @map("backdrop_path")
  firstAirDate       String?   @map("first_air_date")
  lastAirDate        String?   @map("last_air_date")
  status             String? // "Returning Series", "Ended", "Canceled", etc.
  numberOfSeasons    Int?      @map("number_of_seasons")
  numberOfEpisodes   Int?      @map("number_of_episodes")
  episodeRunTime     Int?      @map("episode_run_time") // avg minutes
  contentRating      String?   @map("content_rating") // TV-Y, TV-G, TV-PG, TV-14, TV-MA
  tagline            String?
  popularity         Float?
  voteAverage        Float?    @map("vote_average")
  voteCount          Int?      @map("vote_count")
  trailerKey         String?   @map("trailer_key")
  networks           Json? // [{ id, name, logo_path }]
  watchProviders     Json?     @map("watch_providers")
  providersUpdatedAt DateTime? @map("providers_updated_at")
  cachedAt           DateTime? @map("cached_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  genres           TVShowGenre[]
  cast             TVShowCast[]
  seasons          TVSeason[]
  ratings          TVShowRating[]
  favoritedBy      UserFavoriteShow[]
  watchlistEntries WatchlistShow[]
  rankings         UserMovieRanking[]
  forumThreadMedia ForumThreadMedia[]
  newsItemMedia    NewsItemMedia[]
  blogPostMedia    BlogPostMedia[]
  awards           AwardNomination[]  @relation("tvShowAwards")
  awardForWork     AwardNomination[]  @relation("forWorkTvShow")

  @@map("tv_shows")
}

model TVSeason {
  id           String  @id @default(cuid())
  tvShowId     String  @map("tv_show_id")
  tmdbId       Int     @map("tmdb_id") // TMDB season ID
  seasonNumber Int     @map("season_number")
  name         String?
  overview     String? @db.Text
  posterPath   String? @map("poster_path")
  airDate      String? @map("air_date")
  episodeCount Int?    @map("episode_count")
  voteAverage  Float?  @map("vote_average")

  tvShow   TVShow      @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  episodes TVEpisode[]

  @@unique([tvShowId, seasonNumber])
  @@map("tv_seasons")
}

model TVEpisode {
  id            String  @id @default(cuid())
  seasonId      String  @map("season_id")
  tmdbId        Int     @map("tmdb_id") // TMDB episode ID
  episodeNumber Int     @map("episode_number")
  name          String?
  overview      String? @db.Text
  stillPath     String? @map("still_path") // episode screenshot
  airDate       String? @map("air_date")
  runtime       Int?
  voteAverage   Float?  @map("vote_average")
  voteCount     Int?    @map("vote_count")

  season TVSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, episodeNumber])
  @@map("tv_episodes")
}

model TVShowGenre {
  tvShowId String @map("tv_show_id")
  genreId  Int    @map("genre_id")

  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  genre  Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([tvShowId, genreId])
  @@map("tv_show_genres")
}

model TVShowCast {
  id           String  @id @default(cuid())
  tvShowId     String  @map("tv_show_id")
  celebrityId  String  @map("celebrity_id")
  creditType   String  @default("cast") @map("credit_type") // "cast" | "crew"
  character    String?
  job          String  @default("")
  department   String?
  castOrder    Int     @default(0) @map("cast_order")
  episodeCount Int?    @map("episode_count") // how many episodes they appeared in

  tvShow    TVShow    @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  celebrity Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)

  @@unique([tvShowId, celebrityId, creditType, job])
  @@map("tv_show_cast")
}

model UserFavoriteShow {
  userId    String   @map("user_id")
  tvShowId  String   @map("tv_show_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@id([userId, tvShowId])
  @@map("user_favorite_shows")
}

model EpisodeSeen {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  showTmdbId    Int       @map("show_tmdb_id")
  seasonNumber  Int       @map("season_number")
  episodeNumber Int       @map("episode_number")
  watchedDate   DateTime? @map("watched_date")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, showTmdbId, seasonNumber, episodeNumber])
  @@index([userId, showTmdbId])
  @@index([userId, watchedDate])
  @@map("episode_seen")
}

model WatchlistShow {
  id          String    @id @default(cuid())
  watchlistId String    @map("watchlist_id")
  tvShowId    String    @map("tv_show_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isChecked   Boolean   @default(false) @map("is_checked")
  checkedAt   DateTime? @map("checked_at")
  addedAt     DateTime  @default(now()) @map("added_at")

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  tvShow    TVShow    @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, tvShowId])
  @@map("watchlist_shows")
}

model TVShowRating {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  tvShowId String @map("tv_show_id")

  // "series" = overall show rating, or a specific season number
  ratingScope  String @default("series") @map("rating_scope") // "series" | "season"
  seasonNumber Int    @default(0) @map("season_number") // 0 for series-level, 1+ for seasons

  // Story (weight 5)
  plot               Float?
  premiseOriginality Float? @map("premise_originality")
  storytelling       Float?
  characterDev       Float? @map("character_dev")
  pacingClimax       Float? @map("pacing_climax")

  // Production & Style (weight 3)
  cinematography Float?
  locationCost   Float? @map("location_costuming")
  realism        Float? @map("realism_believability")
  artisticEffect Float? @map("artistic_effect")
  visualEffects  Float? @map("visual_effects")
  musicSound     Float? @map("music_sound")

  // Emotive Effect (weight 3)
  overallEmotion Float? @map("overall_emotion")
  relatability   Float?
  meaning        Float?
  movingness     Float?

  // Acting & Casting (weight 3)
  casting           Float?
  actingQuality     Float? @map("acting_quality")
  dialogueScripting Float? @map("dialogue_scripting")
  blockingChoreo    Float? @map("blocking_choreography")

  // Pure Entertainment (weight 2)
  appeal            Float?
  superficialAllure Float? @map("superficial_allure")
  choreography      Float?

  // Optional overall
  overallRating Float? @map("overall_rating")

  // Cached computed scores
  storyScore     Float? @map("story_score")
  styleScore     Float? @map("style_score")
  emotiveScore   Float? @map("emotive_score")
  actingScore    Float? @map("acting_score")
  entertainScore Float? @map("entertainment_score")
  ratistRating   Float? @map("ratist_rating")

  reviewText       String?   @map("review_text")
  reviewType       String    @default("standard") @map("review_type")
  fieldComments    Json?     @map("field_comments")
  categoryComments Json?     @map("category_comments")
  hasSpoilers      Boolean   @default(false) @map("has_spoilers")
  commentsDisabled Boolean   @default(false) @map("comments_disabled")
  excluded         Boolean   @default(false)
  excludedAt       DateTime? @map("excluded_at")
  excludedReason   String?   @map("excluded_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tvShow TVShow @relation(fields: [tvShowId], references: [id], onDelete: Cascade)

  @@unique([userId, tvShowId, ratingScope, seasonNumber])
  @@map("tv_show_ratings")
}

model MovieRating {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  movieId String @map("movie_id")

  // Story (weight 5) — required: plot, storytelling, pacingClimax
  plot               Float?
  premiseOriginality Float? @map("premise_originality")
  storytelling       Float?
  characterDev       Float? @map("character_dev")
  pacingClimax       Float? @map("pacing_climax")

  // Production & Style (weight 3) — required: cinematography, artisticEffect
  cinematography Float?
  locationCost   Float? @map("location_costuming")
  realism        Float? @map("realism_believability")
  artisticEffect Float? @map("artistic_effect")
  visualEffects  Float? @map("visual_effects")
  musicSound     Float? @map("music_sound")

  // Emotive Effect (weight 3) — required: overallEmotion, relatability
  overallEmotion Float? @map("overall_emotion")
  relatability   Float?
  meaning        Float?
  movingness     Float?

  // Acting & Casting (weight 3) — required: casting (Casting & Subjects), actingQuality (Performance Quality)
  casting           Float?
  actingQuality     Float? @map("acting_quality")
  dialogueScripting Float? @map("dialogue_scripting")
  blockingChoreo    Float? @map("blocking_choreography")

  // Pure Entertainment (weight 2) — required: appeal
  appeal            Float?
  superficialAllure Float? @map("superficial_allure") // excluded from score
  choreography      Float?

  // Optional overall
  overallRating Float? @map("overall_rating")

  // Genre accuracy (optional)
  genreAction      Float? @map("genre_action")
  genreHorror      Float? @map("genre_horror")
  genreDrama       Float? @map("genre_drama")
  genreHistorical  Float? @map("genre_historical")
  genreScifi       Float? @map("genre_scifi")
  genreThriller    Float? @map("genre_thriller")
  genreComedy      Float? @map("genre_comedy")
  genreBookAdapt   Float? @map("genre_book_adaptation")
  genreFantasy     Float? @map("genre_fantasy")
  genreRomance     Float? @map("genre_romance")
  genreDocumentary Float? @map("genre_documentary")
  genreFamily      Float? @map("genre_family")
  genreFilmNoir    Float? @map("genre_film_noir")
  genreMusical     Float? @map("genre_musical")
  genreBiopic      Float? @map("genre_biopic")
  genreCrime       Float? @map("genre_crime")
  genreWestern     Float? @map("genre_western")
  genreMystery     Float? @map("genre_mystery")

  // Cached computed scores
  storyScore     Float? @map("story_score")
  styleScore     Float? @map("style_score")
  emotiveScore   Float? @map("emotive_score")
  actingScore    Float? @map("acting_score")
  entertainScore Float? @map("entertainment_score")
  ratistRating   Float? @map("ratist_rating")

  reviewText       String?   @map("review_text")
  importSource     String?   @map("import_source") // "letterboxd" | "imdb" | "trakt" etc.
  reviewType       String    @default("standard") @map("review_type") // "basic" | "standard" | "critic"
  fieldComments    Json?     @map("field_comments") // critic mode: { "plot": "comment", ... }
  categoryComments Json?     @map("category_comments") // critic mode: { "story": "comment", ... }
  hasSpoilers      Boolean   @default(false) @map("has_spoilers")
  commentsDisabled Boolean   @default(false) @map("comments_disabled")
  excluded         Boolean   @default(false)
  excludedAt       DateTime? @map("excluded_at")
  excludedReason   String?   @map("excluded_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("movie_ratings")
}

// ─── Unified Comments & Likes ─────────────────────────────────────────────────

model Comment {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  targetType         String   @map("target_type") // "review" | "blog" | "lookslike" | "recast" | "hottake" | "oscar_category" | "collection"
  targetId           String   @map("target_id")
  parentId           String?  @map("parent_id")
  text               String
  // Optional GIPHY URL — comments can be text-only, GIF-only, or both.
  // Server requires at least one to be non-empty at insert time.
  gifUrl             String?  @map("gif_url")
  // Optional embedded collection ("reply with your own list"). When set, the
  // comment renders the linked collection as a tappable mini-tile inline.
  // SetNull on collection delete so the comment text survives.
  linkedCollectionId String?  @map("linked_collection_id")
  createdAt          DateTime @default(now()) @map("created_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           Comment?          @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Comment[]         @relation("CommentThread")
  likes            CommentLike[]
  linkedCollection CustomCollection? @relation("CommentLinkedCollection", fields: [linkedCollectionId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([linkedCollectionId])
  @@map("comments")
}

model CommentLike {
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("comment_likes")
}

model PostLike {
  userId     String   @map("user_id")
  targetType String   @map("target_type") // "blog"
  targetId   String   @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, targetType, targetId])
  @@map("post_likes")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  type       String // "comment" | "reply" | "comment_like" | "post_like" | "milestone" | "watchlist_invite" | "invite_accepted"
  actorId    String?  @map("actor_id")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  link       String? // URL to navigate to when clicked
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user  User  @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, type, targetType, targetId])
  @@map("notifications")
}

model UserFavoriteMovie {
