  @@map("forum_thread_follows")
}

// ─── Community Hub ────────────────────────────────────────────────────────────

// Looks Like
model LooksLike {
  id            String   @id @default(cuid())
  creatorId     String   @map("creator_id")
  tmdbPersonId1 Int      @map("tmdb_person_id_1")
  name1         String
  profilePath1  String?  @map("profile_path_1")
  tmdbPersonId2 Int      @map("tmdb_person_id_2")
  name2         String
  profilePath2  String?  @map("profile_path_2")
  createdAt     DateTime @default(now()) @map("created_at")

  creator User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  votes   LooksLikeVote[]

  @@unique([tmdbPersonId1, tmdbPersonId2])
  @@map("looks_likes")
}

model LooksLikeVote {
  userId      String @map("user_id")
  looksLikeId String @map("looks_like_id")
  value       Int // 1 = upvote, -1 = downvote

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  looksLike LooksLike @relation(fields: [looksLikeId], references: [id], onDelete: Cascade)

  @@id([userId, looksLikeId])
  @@map("looks_like_votes")
}

// Oscar Picks
model OscarYear {
  id           String    @id @default(cuid())
  year         Int       @unique
  ceremonyDate DateTime? @map("ceremony_date")
  isComplete   Boolean   @default(false) @map("is_complete") // real ceremony already happened
  createdAt    DateTime  @default(now()) @map("created_at")

  categories OscarCategory[]

  @@map("oscar_years")
}

model OscarCategory {
  id          String @id @default(cuid())
  oscarYearId String @map("oscar_year_id")
  name        String // e.g. "Best Picture"
  slug        String // e.g. "best-picture"
  sortOrder   Int    @default(0) @map("sort_order")

  oscarYear   OscarYear         @relation(fields: [oscarYearId], references: [id], onDelete: Cascade)
  nominees    OscarNominee[]
  votes       OscarVote[]
  suggestions OscarSuggestion[]

  @@unique([oscarYearId, slug])
  @@map("oscar_categories")
}

model OscarNominee {
  id            String  @id @default(cuid())
  categoryId    String  @map("category_id")
  tmdbMovieId   Int?    @map("tmdb_movie_id")
  movieTitle    String  @map("movie_title")
  posterPath    String? @map("poster_path")
  nomineeDetail String? @map("nominee_detail") // e.g. actor name for acting categories
  isWinner      Boolean @default(false) @map("is_winner") // real Oscar winner

  category OscarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes    OscarVote[]

  @@map("oscar_nominees")
}

model OscarVote {
  userId     String @map("user_id")
  categoryId String @map("category_id")
  nomineeId  String @map("nominee_id")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category OscarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nominee  OscarNominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("oscar_votes")
}

model OscarSuggestion {
  id            String   @id @default(cuid())
  categoryId    String   @map("category_id")
  suggesterId   String   @map("suggester_id")
  tmdbMovieId   Int      @map("tmdb_movie_id")
  movieTitle    String   @map("movie_title")
  posterPath    String?  @map("poster_path")
  nomineeDetail String?  @map("nominee_detail") // actor/director name for acting categories
  isApproved    Boolean  @default(false) @map("is_approved") // true once auto-approved at threshold
  isRejected    Boolean  @default(false) @map("is_rejected") // admin rejected
  createdAt     DateTime @default(now()) @map("created_at")

  category  OscarCategory           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  suggester User                    @relation("oscarSuggestions", fields: [suggesterId], references: [id], onDelete: Cascade)
  seconds   OscarSuggestionSecond[]

  @@unique([categoryId, tmdbMovieId, nomineeDetail])
  @@map("oscar_suggestions")
}

model OscarSuggestionSecond {
  userId       String   @map("user_id")
  suggestionId String   @map("suggestion_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion OscarSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@id([userId, suggestionId])
  @@map("oscar_suggestion_seconds")
}

// Recast
model Recast {
  id                    String   @id @default(cuid())
  creatorId             String   @map("creator_id")
  tmdbMovieId           Int      @map("tmdb_movie_id")
  movieTitle            String   @map("movie_title")
  posterPath            String?  @map("poster_path")
  characterName         String   @map("character_name")
  originalActorName     String   @map("original_actor_name")
  originalActorTmdbId   Int?     @map("original_actor_tmdb_id")
  suggestedActorName    String   @map("suggested_actor_name")
  suggestedActorTmdbId  Int?     @map("suggested_actor_tmdb_id")
  suggestedActorProfile String?  @map("suggested_actor_profile")
  createdAt             DateTime @default(now()) @map("created_at")

  creator User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  votes   RecastVote[]

  @@map("recasts")
}

model RecastVote {
  userId   String @map("user_id")
  recastId String @map("recast_id")
  value    Int // 1 = agree, -1 = disagree

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recast Recast @relation(fields: [recastId], references: [id], onDelete: Cascade)

  @@id([userId, recastId])
  @@map("recast_votes")
}

// Hot Takes
model HotTake {
  id        String   @id @default(cuid())
  authorId  String   @map("author_id")
  content   String // max 280 chars
  createdAt DateTime @default(now()) @map("created_at")

  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes  HotTakeVote[]

  @@map("hot_takes")
}

model HotTakeVote {
  userId    String @map("user_id")
  hotTakeId String @map("hot_take_id")
  value     Int // 1 = "hot", -1 = "not"

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotTake HotTake @relation(fields: [hotTakeId], references: [id], onDelete: Cascade)

  @@id([userId, hotTakeId])
  @@map("hot_take_votes")
}

// ─── Cine-Q Quiz ─────────────────────────────────────────────────────────────

model CineQDaily {
  id         String   @id @default(cuid())
  date       String // "2026-04-06" (Pacific time)
  mediaType  String   @map("media_type") // "movie" | "tv" | "both"
  difficulty String // "easy" | "medium" | "hard"
  questions  Json // array of question objects (title, tmdbId, clues, options)
  createdAt  DateTime @default(now()) @map("created_at")

  attempts CineQAttempt[]

  @@unique([date, mediaType, difficulty])
  @@map("cineq_daily")
}

model CineQAttempt {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  dailyId    String?  @map("daily_id") // null for practice mode
  mediaType  String   @map("media_type")
  difficulty String
  mode       String   @default("daily") // "daily" | "practice"
  status     String   @default("completed") // "in_progress" | "completed" | "abandoned"
  rawScore   Float    @default(0) @map("raw_score")
  answers    Json? // array of { questionIndex, correct, timeElapsed, wrongGuesses }
  createdAt  DateTime @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  daily CineQDaily? @relation(fields: [dailyId], references: [id], onDelete: SetNull)

  @@unique([userId, dailyId]) // one attempt per user per daily quiz
  @@map("cineq_attempts")
}

// ─── Movie Club ──────────────────────────────────────────────────────────────

model MovieClubWeek {
  id         String @id @default(cuid())
  weekNumber Int    @map("week_number")
  startDate  String @map("start_date") // "2026-04-07" Monday
  endDate    String @map("end_date") // "2026-04-13" Sunday
  // scheduled → voting (community_vote only, Mon-Tue) → watching (Wed or Mon) → discussion (Fri 8pm ET) → archived (next Mon)
  status     String @default("scheduled")

  pickMethod  String  @default("random") @map("pick_method") // "admin" | "random" | "community_vote"
  pickFilters Json?   @map("pick_filters")
  pickTeaser  String? @map("pick_teaser")
  revealEarly Boolean @default(false) @map("reveal_early") // show movie in Coming Up before week starts

  movieId     String? @map("movie_id")
  movieTmdbId Int?    @map("movie_tmdb_id")
  movieTitle  String? @map("movie_title")
  moviePoster String? @map("movie_poster")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  movie        Movie?                 @relation(fields: [movieId], references: [id])
  ratings      MovieClubRating[]
  nominations  MovieClubNomination[]
  rewatchPolls MovieClubRewatchPoll[]

  @@unique([weekNumber])
  @@map("movie_club_weeks")
}

model MovieClubMember {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("movie_club_members")
}

model MovieClubRating {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  weekId       String   @map("week_id")
  rating       Float // overall 1-10
  reviewText   String?  @map("review_text") @db.Text
  reviewType   String   @default("quick") @map("review_type") // "quick" | "standard"
  formData     Json?    @map("form_data") // full rubric scores from ScreeningRateForm
  isRewatch    Boolean  @default(false) @map("is_rewatch")
  madeOfficial Boolean  @default(false) @map("made_official")
  createdAt    DateTime @default(now()) @map("created_at")

  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  week      MovieClubWeek             @relation(fields: [weekId], references: [id], onDelete: Cascade)
  reactions MovieClubReviewReaction[]

  @@unique([userId, weekId])
  @@map("movie_club_ratings")
}

model MovieClubNomination {
  id         String   @id @default(cuid())
  weekId     String   @map("week_id")
  userId     String   @map("user_id")
  tmdbId     Int      @map("tmdb_id")
  title      String
  posterPath String?  @map("poster_path")
  createdAt  DateTime @default(now()) @map("created_at")

  week  MovieClubWeek             @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes MovieClubNominationVote[]

  @@unique([weekId, tmdbId]) // no duplicate nominations per week
  @@map("movie_club_nominations")
}

model MovieClubNominationVote {
  id           String   @id @default(cuid())
  nominationId String   @map("nomination_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  nomination MovieClubNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nominationId, userId])
  @@map("movie_club_nomination_votes")
}

model MovieClubRewatchPoll {
  id     String @id @default(cuid())
  userId String @map("user_id")
  weekId String @map("week_id")
  vote   String // "yes" | "no" | "maybe"

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  week MovieClubWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([userId, weekId])
  @@map("movie_club_rewatch_polls")
}

model MovieClubReviewReaction {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  ratingId String @map("rating_id")
  value    String // "agree" | "disagree"

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating MovieClubRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@unique([userId, ratingId])
  @@map("movie_club_review_reactions")
}

// Movie/Show Pitches
model MoviePitch {
  id          String   @id @default(cuid())
  authorId    String   @map("author_id")
  title       String // pitch title (max 100)
  description String   @db.Text // longer description (max 1000)
  mediaType   String   @default("movie") @map("media_type") // "movie" | "tv"
  genre       String? // optional genre tag
  createdAt   DateTime @default(now()) @map("created_at")

  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes  MoviePitchVote[]

  @@map("movie_pitches")
}

model MoviePitchVote {
  userId  String @map("user_id")
  pitchId String @map("pitch_id")
  value   Int // 1 = upvote, -1 = downvote

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitch MoviePitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@id([userId, pitchId])
  @@map("movie_pitch_votes")
}

// ─── Screening Room ───────────────────────────────────────────────────────────

enum ScreeningSessionStatus {
  LOBBY
  COUNTDOWN
  WATCHING
  POST_WATCH
  COMPLETE
}

model ScreeningSession {
  id         String                 @id @default(cuid())
  hostId     String                 @map("host_id")
  movieId    String?                @map("movie_id")
  tmdbId     Int?                   @map("tmdb_id")
  movieTitle String?                @map("movie_title")
  posterPath String?                @map("poster_path")
  mediaType  String                 @default("movie") @map("media_type")
  status     ScreeningSessionStatus @default(LOBBY)
  inviteCode String                 @unique @map("invite_code")
  startedAt  DateTime?              @map("started_at")
  finishedAt DateTime?              @map("finished_at")
  // Per-minute chat-message counts captured when the host generates
  // highlights. ChatHighlight rows only persist the top-3 burst windows
  // (max 25 msgs each), which made the OG-card reaction timeline read
  // as sparse compared to the in-app heatmap. This array carries one
  // count per minute of the watch so the OG strip can rebucket at any
  // granularity and exactly mirror the post-watch chart.
  chatBucketCounts Json?            @map("chat_bucket_counts")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  host           User                     @relation("screeningHost", fields: [hostId], references: [id], onDelete: Cascade)
  movie          Movie?                   @relation(fields: [movieId], references: [id])
  participants   ScreeningParticipant[]
  predictions    ScreeningPrediction[]
  polls          ScreeningPoll[]
  bookmarks      ScreeningBookmark[]
  chatHighlights ScreeningChatHighlight[]
  ratings        ScreeningRating[]

  @@map("screening_sessions")
}

model ScreeningParticipant {
  sessionId   String   @map("session_id")
  userId      String   @map("user_id")
  joinedAt    DateTime @default(now()) @map("joined_at")
  hasAds      Boolean  @default(false) @map("has_ads")
  hasFinished Boolean  @default(false) @map("has_finished")
  hidden      Boolean  @default(false)

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@map("screening_participants")
}

model ScreeningPrediction {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  userId      String   @map("user_id")
  plotGuess   String?  @map("plot_guess")
  ratingGuess Float?   @map("rating_guess")
  createdAt   DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("screening_predictions")
}

model ScreeningPoll {
  id        String    @id @default(cuid())
  sessionId String    @map("session_id")
  creatorId String    @map("creator_id")
  question  String
  options   Json // string[]
  votes     Json      @default("{}") // { [userId]: optionIndex }
  revealAt  String    @default("instant") @map("reveal_at") // "instant" | "end"
  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  creator User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("screening_polls")
}

model ScreeningBookmark {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String   @map("user_id")
  timestamp String // movie timestamp e.g. "01:23:45"
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("screening_bookmarks")
}

model ScreeningChatHighlight {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  userId      String   @map("user_id")
  text        String
  emoji       String?
  reactCount  Int      @default(0) @map("react_count") // total messages in this window
  windowGroup Int      @default(0) @map("window_group") // which burst this belongs to (0, 1, 2)
  timestamp   DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("screening_chat_highlights")
}

model ScreeningRating {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  userId    String @map("user_id")

  reviewType String @default("standard") @map("review_type") // "basic" | "standard"

  // Story
  plot               Float?
  premiseOriginality Float? @map("premise_originality")
  storytelling       Float?
  characterDev       Float? @map("character_dev")
  pacingClimax       Float? @map("pacing_climax")

  // Production & Style
  cinematography Float?
  locationCost   Float? @map("location_costuming")
  realism        Float? @map("realism_believability")
  artisticEffect Float? @map("artistic_effect")
  visualEffects  Float? @map("visual_effects")
  musicSound     Float? @map("music_sound")

  // Emotive Effect
  overallEmotion Float? @map("overall_emotion")
  relatability   Float?
  meaning        Float?
  movingness     Float?

  // Acting & Casting
  casting           Float?
  actingQuality     Float? @map("acting_quality")
  dialogueScripting Float? @map("dialogue_scripting")
  blockingChoreo    Float? @map("blocking_choreography")

  // Pure Entertainment
  appeal            Float?
  superficialAllure Float? @map("superficial_allure")
  choreography      Float?

  // Overall
  overallRating Float? @map("overall_rating")

  // Computed
  storyScore     Float? @map("story_score")
  styleScore     Float? @map("style_score")
  emotiveScore   Float? @map("emotive_score")
  actingScore    Float? @map("acting_score")
  entertainScore Float? @map("entertainment_score")
  ratistRating   Float? @map("ratist_rating")

  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("screening_ratings")
}

model Report {
  id         String    @id @default(cuid())
  targetType String    @map("target_type") // "review" | "comment" | "forumPost" | "hotTake" | "recast" | "looksLike"
  targetId   String    @map("target_id")
  reporterId String    @map("reporter_id")
  reason     String // "spam" | "harassment" | "inappropriate" | "spoilers" | "other"
  details    String? // optional user-provided detail
  status     String    @default("pending") // "pending" | "dismissed" | "removed" | "warned" | "banned"
  resolvedBy String?   @map("resolved_by") // admin user ID
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  reporter User  @relation("reportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("reportsResolved", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@map("reports")
}

model Feedback {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id") // null for non-logged-in users
  email      String? // for non-logged-in users or contact
  category   String // "bug" | "inaccurate_info" | "feature_request" | "account_issue" | "content_issue" | "other"
  message    String    @db.Text
  status     String    @default("open") // "open" | "in_progress" | "resolved" | "closed"
  adminReply String?   @map("admin_reply") @db.Text
  repliedBy  String?   @map("replied_by")
  repliedAt  DateTime? @map("replied_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User? @relation("feedbackSubmitted", fields: [userId], references: [id], onDelete: SetNull)
  replier User? @relation("feedbackReplied", fields: [repliedBy], references: [id], onDelete: SetNull)

  @@map("feedback")
}

// External /contact page submissions — distinct from /feedback (which is
// for in-product user feedback). Contact is for advertising inquiries,
// press/media, partnerships, DMCA notices, etc. Submitters are typically
// not logged-in users, so we always require name + email up front.
// Admins typically reply via their own email client to the inquirer's
// address, so we only track internal notes + handler audit, not an
// in-app reply thread.
model Contact {
  id         String    @id @default(cuid())
  name       String
  email      String
  company    String?
  category   String // "general" | "advertising" | "press" | "partnerships" | "dmca" | "other"
  subject    String?
  message    String    @db.Text
  status     String    @default("open") // "open" | "in_progress" | "resolved" | "closed"
  adminNotes String?   @map("admin_notes") @db.Text
  handledBy  String?   @map("handled_by")
  handledAt  DateTime? @map("handled_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  handler User? @relation("contactHandled", fields: [handledBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@map("contacts")
}

// User-submitted requests to regenerate their invite code (the share
// code on their profile used by the recommend tool's group mode).
// Admin-approved: the request lands in /admin/invite-codes, an admin
// approves or denies, and approval auto-rotates the user's
// User.inviteCode. Pattern mirrors Feedback / Contact queues.
model InviteCodeRequest {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  status     String    @default("pending") // "pending" | "approved" | "denied"
  reason     String?   @db.Text
  oldCode    String?   @map("old_code") // snapshot for audit
  newCode    String?   @map("new_code") // populated on approval
  adminNotes String?   @map("admin_notes") @db.Text
  resolvedBy String?   @map("resolved_by") // admin user.id
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User  @relation("inviteCodeRequester", fields: [userId], references: [id], onDelete: Cascade)
  resolver User? @relation("inviteCodeResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, status])
  @@map("invite_code_requests")
}

model PostIdea {
  id          String   @id @default(cuid())
  type        PostType // PUNCH_AND_JUDY | MOVIE_MAP (BLOG not exposed for user submissions)
  submitterId String?  @map("submitter_id")
  description String   @db.Text

  // Optional linked movie/show
  mediaTmdbId     Int?    @map("media_tmdb_id")
  mediaType       String? @map("media_type") // "movie" | "tv"
  mediaTitle      String? @map("media_title")
  mediaPosterPath String? @map("media_poster_path")

  // Optional linked celebrity
  personTmdbId      Int?    @map("person_tmdb_id")
  personName        String? @map("person_name")
  personProfilePath String? @map("person_profile_path")

  status     String    @default("pending") // "pending" | "accepted" | "rejected" | "completed"
  adminNotes String?   @map("admin_notes") @db.Text
  reviewedBy String?   @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  submitter User? @relation("ideasSubmitted", fields: [submitterId], references: [id], onDelete: SetNull)
  reviewer  User? @relation("ideasReviewed", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@map("post_ideas")
}

// User-saved AI-generated collections. The items array is a frozen snapshot
// so we can render saved collections without re-hitting TMDB for metadata.
model CustomCollection {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  name          String
  description   String?   @db.Text
  prompt        String    @db.Text
  mediaType     String    @default("movie") @map("media_type") // "movie" | "tv" | "any"
  // "private" (default) — only the owner sees it. AI-built collections stay
  // here unless the owner opts in. "public" — listed in the community feed,
  // commentable, saveable. "unlisted" — accessible by direct URL but not
  // surfaced in the feed; used when a curator wants to share a draft link
  // without committing to public discovery.
  visibility    String    @default("private")
  // Slug + publishedAt are set together when a collection is published. Both
  // null means draft/private. Slug is unique per user so two curators can use
  // the same human-readable name.
  slug          String?
  publishedAt   DateTime? @map("published_at")
  // Optional hero image (TMDB backdrop path or uploaded asset).
  coverPath     String?   @map("cover_path")
  // FK to an admin-authored theme prompt the curator was responding to.
  // Drives the "Theme" tab on the community feed (Phase 3 UI; column ships
  // now so we don't need a follow-up migration).
  themePromptId String?   @map("theme_prompt_id")
  // Admin-flagged "official" curation. The collection still has a userId
  // (every row needs an author), but the public-facing UI suppresses the
  // curator's name in favour of "Curated by Ratist" attribution and the
  // Featured tab pulls from this flag instead of curator.isAdmin.
  isOfficial    Boolean   @default(false) @map("is_official")
  // When true, the public detail page renders ordinal numbers (1, 2, 3…)
  // alongside each item — used for canonical watch orders on saga
  // collections (e.g. MCU Infinity Saga in chronological order).
  numberedOrder Boolean   @default(false) @map("numbered_order")
  // Denormalized engagement counts kept in sync by the save toggle / view
  // tracker. Used for popular-sort and milestone notifications.
  saveCount     Int       @default(0) @map("save_count")
  viewCount     Int       @default(0) @map("view_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  themePrompt CollectionPrompt?      @relation(fields: [themePromptId], references: [id], onDelete: SetNull)
  items       CustomCollectionItem[]
  tags        CollectionTag[]
  saves       CollectionSave[]
  comments    Comment[]              @relation("CommentLinkedCollection")
  matchCache  CollectionMatchCache[]

  @@unique([userId, slug])
  @@index([userId, createdAt])
  @@index([visibility, publishedAt])
  @@index([visibility, saveCount])
  @@index([themePromptId])
  @@index([isOfficial, publishedAt])
  @@map("custom_collections")
}

model CustomCollectionItem {
  id           String  @id @default(cuid())
  collectionId String  @map("collection_id")
  mediaType    String  @map("media_type") // "movie" | "tv"
  tmdbId       Int     @map("tmdb_id")
  title        String
  posterPath   String? @map("poster_path")
  releaseDate  String? @map("release_date")
  voteAverage  Float?  @map("vote_average")
  sortOrder    Int     @default(0) @map("sort_order")
  // Curator's per-entry note ("why this one"). Surfaced inline in the
  // public detail view; nullable so AI-built items don't need to backfill.
  blurb        String? @db.Text

  collection CustomCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, mediaType, tmdbId])
  @@index([collectionId, sortOrder])
  @@map("custom_collection_items")
}

// Free-form lowercase tags on a collection. Mirrors ForumThreadTag —
// sanitized client-side ([a-z0-9-]), no admin allowlist. Only public
// collections expose tags in the community feed.
model CollectionTag {
  id           String @id @default(cuid())
  collectionId String @map("collection_id")
  tag          String

  collection CustomCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, tag])
  @@index([tag])
  @@map("collection_tags")
}

// Bookmark / "I want to come back to this" on a public collection.
// Drives popular-sort (saveCount denormalized on the parent) and
// milestone notifications.
model CollectionSave {
  userId       String   @map("user_id")
  collectionId String   @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection CustomCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userId, collectionId])
  @@index([userId, createdAt])
  @@index([collectionId, createdAt])
  @@map("collection_saves")
}

// Cached per-user match score for a collection (0-100 or null when not
// enough community data exists to predict). Computed lazily on first
// feed view via getOrComputeMatchScoresBatch and invalidated on item
// changes (collection-side) or profile rebuild (user-side).
model CollectionMatchCache {
  userId       String   @map("user_id")
  collectionId String   @map("collection_id")
  // Caching null avoids redundant compute when the prediction returns
  // nothing — e.g. a user with no profile yet, or a collection of
  // movies with no community ratings. Refresh happens on cache wipe.
  score        Int?
  computedAt   DateTime @default(now()) @map("computed_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection CustomCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userId, collectionId])
  // Wipe-by-collection (item changes) and wipe-by-user (profile rebuild).
  @@index([collectionId])
  // Match-tab orderBy uses (userId, score desc).
  @@index([userId, score])
  @@map("collection_match_cache")
}

// Admin-authored themed prompts ("Films that aged like wine"). Curators
// respond by tagging their collection with the prompt; the Theme tab on
// the community feed groups responses.
// Phase 3 surfaces this in admin UI; Phase 1 ships the table only.
model CollectionPrompt {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  activeFrom  DateTime? @map("active_from")
  activeTo    DateTime? @map("active_to")
  featured    Boolean   @default(false)
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy   User?              @relation("CollectionPromptAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  collections CustomCollection[]

  @@index([activeFrom, activeTo])
  @@index([featured])
  @@map("collection_prompts")
}

// Cached parents'-guide severities (from DoesTheDogDie) per movie. Written
// through on every /api/movies/[id]/parents-guide fetch so values track live
// DDD vote data. Read by AI filter routes without triggering DDD calls.
model MovieParentsGuide {
  tmdbId                    Int      @id @map("tmdb_id")
  violenceSeverity          String   @map("violence_severity") // "none" | "mild" | "mild-moderate" | "moderate" | "moderate-severe" | "severe"
  sexualSeverity            String   @map("sexual_severity")
  languageSubstanceSeverity String   @map("language_substance_severity")
  scaryIntenseSeverity      String   @map("scary_intense_severity")
  sensitiveThemesSeverity   String   @map("sensitive_themes_severity")
  totalVoters               Int      @default(0) @map("total_voters")
  limitedData               Boolean  @default(false) @map("limited_data")
  fetchedAt                 DateTime @default(now()) @map("fetched_at")

  @@map("movie_parents_guides")
}

// Cached AI-generated community review summaries, keyed by TMDB id + media type.
// Regenerated when the review count has grown meaningfully since last generation.
model ReviewDigest {
  id          String   @id @default(cuid())
  mediaType   String   @map("media_type") // "movie" | "tv"
  tmdbId      Int      @map("tmdb_id")
  digest      String   @db.Text
  reviewCount Int      @map("review_count") // review count at generation time
  model       String   @default("claude-haiku-4-5")
  generatedAt DateTime @default(now()) @map("generated_at")

  @@unique([mediaType, tmdbId])
  @@map("review_digests")
}

// Tracks AI feature usage for rate limiting. Paid (Backstage Pass) and admin
// users bypass rate limits — this table is only consulted for free users.
model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  feature   String // e.g. "recommend"
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
  @@map("ai_usage_logs")
}

model SiteSpotlight {
  id          String    @id @default(cuid())
  title       String
  description String?
  linkUrl     String    @map("link_url")
  linkLabel   String    @default("Read more") @map("link_label")
  imageUrl    String?   @map("image_url")
  type        String    @default("general") // "blog" | "punch_and_judy" | "feature" | "announcement" | "general"
  placement   String    @default("homepage") // "homepage" | "for_you" | "movies" | "community" | "all"
  style       String    @default("subtle") // "subtle" | "bold" | "gradient"
  bgColor     String?   @map("bg_color") // custom hex accent color, null = default red
  audience    String    @default("everyone") // "everyone" | "signed_in" | "signed_out" | "non_subscriber" | "new_user"
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  dismissals SpotlightDismissal[]

  @@map("site_spotlights")
}

// Per-user "I've already dismissed this banner" record. Lets the
// dismissal persist across devices and sessions — a user who
// dismissed the policy-update banner on desktop doesn't see it again
// when they sign in on mobile. Anonymous visitors still fall back
// to the older localStorage-only path on the client.
model SpotlightDismissal {
  userId      String   @map("user_id")
  spotlightId String   @map("spotlight_id")
  dismissedAt DateTime @default(now()) @map("dismissed_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotlight SiteSpotlight @relation(fields: [spotlightId], references: [id], onDelete: Cascade)

  @@id([userId, spotlightId])
  @@index([userId])
  @@map("spotlight_dismissals")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  action    String // "ban" | "unban" | "softDelete" | "restore" | "permanentDelete" | "toggleAdmin" | "removeContent" | "notify" | "resolveReport"
  targetId  String?  @map("target_id") // user or report ID
  details   String? // description of what happened
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation("adminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_logs")
}

// ─── Badges / Achievements ──────────────────────────────────────────────────

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  slug     String // matches code-side badge registry key
  earnedAt DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId, earnedAt])
  @@map("user_badges")
}

// ─── Awards & Nominations ──────────────────────────────────────────────────

model AwardBody {
  id         String   @id @default(cuid())
  slug       String   @unique // "oscar", "golden-globe", "bafta", "sag", "cannes"
  name       String // "Academy Awards"
  shortName  String   @map("short_name") // "Oscar"
  wikidataId String?  @unique @map("wikidata_id") // Q19020 for Oscars
  createdAt  DateTime @default(now()) @map("created_at")

  categories AwardCategory[]

  @@map("award_bodies")
}

model AwardCategory {
  id          String  @id @default(cuid())
  awardBodyId String  @map("award_body_id")
  slug        String // "best-picture", "best-director"
  name        String // "Best Picture"
  wikidataId  String? @map("wikidata_id")
  sortOrder   Int     @default(0) @map("sort_order")

  awardBody   AwardBody         @relation(fields: [awardBodyId], references: [id], onDelete: Cascade)
  nominations AwardNomination[]

  @@unique([awardBodyId, slug])
  @@map("award_categories")
}

model AwardNomination {
  id         String  @id @default(cuid())
  categoryId String  @map("category_id")
  isWinner   Boolean @default(false) @map("is_winner")
  year       Int?
  ceremony   String?

  // Polymorphic subject — the entity that was nominated/won
  movieId     String? @map("movie_id")
  tvShowId    String? @map("tv_show_id")
  celebrityId String? @map("celebrity_id")

  // "For work" reference — person won award FOR this specific film/show
  forMovieId  String? @map("for_movie_id")
  forTvShowId String? @map("for_tv_show_id")

  wikidataId String? @map("wikidata_id") // for dedup during import
  dedupKey   String  @unique @map("dedup_key") // computed key for upsert dedup

  category  AwardCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  movie     Movie?        @relation("movieAwards", fields: [movieId], references: [id], onDelete: Cascade)
  tvShow    TVShow?       @relation("tvShowAwards", fields: [tvShowId], references: [id], onDelete: Cascade)
  celebrity Celebrity?    @relation("celebrityAwards", fields: [celebrityId], references: [id], onDelete: Cascade)
  forMovie  Movie?        @relation("forWorkMovie", fields: [forMovieId], references: [id], onDelete: SetNull)
  forTvShow TVShow?       @relation("forWorkTvShow", fields: [forTvShowId], references: [id], onDelete: SetNull)

  @@index([movieId])
  @@index([tvShowId])
  @@index([celebrityId])
  @@index([year])
  @@map("award_nominations")
}

model AwardsSyncLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type") // "movie", "tvshow", "celebrity"
  entityId   String   @map("entity_id")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@unique([entityType, entityId])
  @@map("awards_sync_log")
}

// ─── News ───────────────────────────────────────────────────────────────────

enum NewsItemType {
  EDITORIAL
  TRAILER
  RELEASE_CHANGE
  NEW_SEASON
  ANNOUNCEMENT
}

model NewsItem {
  id          String       @id @default(cuid())
  type        NewsItemType
  title       String
  slug        String?      @unique
  content     String?      @db.Text
  excerpt     String?
  coverImage  String?      @map("cover_image")
  published   Boolean      @default(false)
  publishedAt DateTime?    @map("published_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  authorId String? @map("author_id")
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  movieTmdbId Int?    @map("movie_tmdb_id")
  showTmdbId  Int?    @map("show_tmdb_id")
  posterPath  String? @map("poster_path")

  youtubeKey String? @map("youtube_key")
  sourceUrl  String? @map("source_url")
  sourceName String? @map("source_name")
  meta       Json?

  showAuthor  Boolean          @default(true) @map("show_author")
  externalKey String?          @unique @map("external_key")
  viewCount   Int              @default(0) @map("view_count")
  media       NewsItemMedia[]
  people      NewsItemPerson[]

  @@index([published, publishedAt])
  @@index([type, published])
  @@map("news_items")
}

model NewsItemMedia {
  id         String  @id @default(cuid())
  newsItemId String  @map("news_item_id")
  movieId    String? @map("movie_id")
  tvShowId   String? @map("tv_show_id")
  tmdbId     Int     @map("tmdb_id")
  mediaType  String  @map("media_type") // "movie" | "tv"
  title      String
  posterPath String? @map("poster_path")

  newsItem NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  movie    Movie?   @relation(fields: [movieId], references: [id])
  tvShow   TVShow?  @relation(fields: [tvShowId], references: [id])

  @@map("news_item_media")
}

model NewsItemPerson {
  id          String  @id @default(cuid())
  newsItemId  String  @map("news_item_id")
  celebrityId String? @map("celebrity_id")
  tmdbId      Int     @map("tmdb_id")
  name        String
  profilePath String? @map("profile_path")

  newsItem  NewsItem   @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  celebrity Celebrity? @relation(fields: [celebrityId], references: [id])

  @@map("news_item_people")
}

model RssHeadline {
  id          String   @id @default(cuid())
  feedSource  String   @map("feed_source")
  title       String
  url         String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  dismissed   Boolean  @default(false)
  usedInPost  String?  @map("used_in_post")

  @@index([dismissed, fetchedAt])
  @@map("rss_headlines")
}

// ─── Fraud Detection ──────────────────────────────────────────────────────────

model FraudFlag {
  id       String @id @default(cuid())
  type     String // "duplicate_cluster" | "review_bomb" | "thin_account"
  status   String @default("open") // "open" | "excluded" | "dismissed"
  severity String @default("medium") // "low" | "medium" | "high"

  // For duplicate_cluster: JSON array of user IDs in the cluster
  // For review_bomb: the target movie/show tmdb ID
  // For thin_account: the user ID
  userIds    Json    @map("user_ids") // string[]
  targetType String? @map("target_type") // "movie" | "show" | null
  targetId   String? @map("target_id") // movie or tvShow DB id

  // Evidence snapshot
  evidence Json // { matchRate, sharedCount, ratings, ... }

  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by") // admin user ID

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, type])
  @@map("fraud_flags")
}

// ─── Watch Companion ──────────────────────────────────────────────────────────
// AI+community-generated viewing-guide data for a movie or TV show. One record
// per (tmdbId, mediaType). For shows, seasons are generated incrementally into
// the same companion record; seasonsGenerated tracks which are populated.

model WatchCompanion {
  id               String @id @default(cuid())
  tmdbId           Int    @map("tmdb_id")
  mediaType        String @map("media_type") // "movie" | "tv"
  title            String // snapshot of movie/show title at generation time
  runtimeSeconds   Int?   @map("runtime_seconds") // for movies — spoiler-slider max
  seasonsGenerated Int[]  @default([]) @map("seasons_generated") // for tv — which seasons have been populated

  // Published/draft workflow. Drafts exist only for admin review; published
  // companions render publicly on the show/movie page.
  status          String    @default("draft") // "draft" | "published"
  generatedBy     String?   @map("generated_by") // userId who triggered the first generation
  lastGeneratedAt DateTime? @map("last_generated_at")
  publishedAt     DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Recap blob for the "what happened previously" tab. Movies store
  //   { current: { title, year, text }, prior: [{tmdbId, title, year, text}, ...] }
  // (prior is empty for standalone movies, ordered chronologically).
  // TV companions store per-season recaps keyed by season number as
  //   { "1": "S1 recap", "2": "S2 recap", ... }
  // Each season gen overwrites only its own slot. Hidden behind a
  // reveal button on the public viewer because the recap intentionally
  // contains full spoilers — it's a "catch me up before the next
  // installment" tool, not a slider-gated discovery surface.
  recaps        Json?
  generator     User?                    @relation("companionGenerator", fields: [generatedBy], references: [id], onDelete: SetNull)
  characters    CompanionCharacter[]
  relationships CompanionRelationship[]
  timeline      CompanionTimelineEvent[]
  glossary      CompanionGlossaryTerm[]
  suggestions   CompanionSuggestion[]
  ratings       WatchCompanionRating[]
  airingSeasons CompanionAiringSeason[]
  follows       CompanionFollow[]

  @@unique([tmdbId, mediaType])
  @@index([status])
  @@map("watch_companions")
}

// User-submitted "was this companion helpful?" ratings. One vote per user
// per companion (upsert on the unique pair). vote: 1 = thumbs up,
// -1 = thumbs down. Counts and comments are admin-only — the front-end
// never displays aggregates so a brigaded show can't visibly trash a
// companion before the admin gets a chance to fix it. Cascade on
// companion delete; SetNull on user delete so admin can still see
// historical feedback after an account is removed.
model WatchCompanionRating {
  id           String   @id @default(cuid())
  companionId  String   @map("companion_id")
  userId       String?  @map("user_id")
  // Season scope. 0 for movies (no seasons), 1+ for TV seasons. Lets a
  // viewer rate Season 1 of GoT positively and Season 2 negatively as
  // independent votes — the unique constraint is per-season so the
  // upsert in the rate endpoint targets the right row.
  seasonNumber Int      @default(0) @map("season_number")
  vote         Int // 1 (thumbs up) or -1 (thumbs down)
  comment      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companion WatchCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([companionId, userId, seasonNumber])
  @@index([companionId, seasonNumber, vote])
  @@map("watch_companion_ratings")
}

// A character in a companion. baseDescription is always visible (spoiler-safe
// intro — "The Roy family patriarch" for Logan). Evolving facts (role changes,
// arcs, deaths) live in CompanionFact with per-moment visibleAfter.

model CompanionCharacter {
  id              String  @id @default(cuid())
  companionId     String  @map("companion_id")
  // Per-season ownership for TV companions. Null for movies. A character who
  // appears in S1 and S2 exists as TWO rows (one per season) so the
  // regeneration of S2 leaves S1 untouched and each season's row can carry
  // a different baseDescription / facts / imageUrl snapshot.
  seasonNumber    Int?    @map("season_number")
  name            String
  // Primary actor — kept for backward compatibility with pre-multi-actor
  // data and as a fallback when the CompanionCharacterActor side-table is
  // empty. New generations populate this with the earliest (first-visible)
  // actor and ALSO write the full list to the side-table.
  actorName       String? @map("actor_name")
  actorTmdbId     Int?    @map("actor_tmdb_id")
  baseDescription String  @map("base_description") @db.Text

  // When the character first appears. For movies: seconds into runtime.
  // For shows: { season, episode, seconds? }.
  visibleAfter Json @map("visible_after") // { seconds?, season?, episode? }

  // Optional primary faction / group (for coloring in diagrams — "Waystar",
  // "House Stark", etc.)
  group    String?
  imageUrl String? @map("image_url") // headshot; usually TMDB profile path

  // Alias names for twist-reveal characters. Array of { name, visibleAfter }
  // where each entry is the name the character is known by after its reveal
  // moment. The viewer picks the alias with the latest visibleAfter that is
  // <= the current slider position, falling back to the primary `name`.
  // Example: Star Trek Into Darkness —
  //   name: "John Harrison"
  //   nameAliases: [{ name: "Khan", visibleAfter: { seconds: 6300 } }]
  nameAliases Json? @map("name_aliases")

  // Group/faction history for characters who switch sides or have hidden
  // allegiances. Same shape as nameAliases — array of { group, visibleAfter }.
  // The viewer picks the latest unlocked entry's group, falling back to the
  // primary `group` column when nothing has unlocked yet. Examples:
  //   - Severus Snape: group "Death Eaters" (cover), groupHistory entry
  //     { group: "Order of the Phoenix", visibleAfter: <reveal moment> }
  //   - FN-2187 → Finn: group "First Order", groupHistory entry
  //     { group: "Resistance", visibleAfter: <defection moment> }
  groupHistory Json? @map("group_history")

  sortOrder Int @default(0) @map("sort_order")

  companion         WatchCompanion            @relation(fields: [companionId], references: [id], onDelete: Cascade)
  actors            CompanionCharacterActor[]
  facts             CompanionFact[]
  fromRelationships CompanionRelationship[]   @relation("relFrom")
  toRelationships   CompanionRelationship[]   @relation("relTo")

  @@index([companionId])
  @@index([companionId, seasonNumber])
  @@map("companion_characters")
}

// Multiple-actor mapping for characters played by more than one person —
// covers age variants (young/adult/elderly Murph in Interstellar), twins
// playing one role (Winklevoss twins in The Social Network), and mid-show
// recastings (Dark's triple-casting of major characters). Each entry has
// its own visibleAfter so the viewer can unlock actors one at a time as
// the story reveals them.
model CompanionCharacterActor {
  id           String  @id @default(cuid())
  characterId  String  @map("character_id")
  actorName    String  @map("actor_name")
  actorTmdbId  Int?    @map("actor_tmdb_id")
  // Human-readable context label: "young", "adult", "elderly", "twin",
  // etc. Null for single-actor characters where the label would be noise.
  note         String?
  // When this actor's version of the character is first revealed on-screen.
  visibleAfter Json    @map("visible_after")
  sortOrder    Int     @default(0) @map("sort_order")

  character CompanionCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@map("companion_character_actors")
}

// A fact about a character that unlocks as the viewer progresses. "Becomes
// acting CEO in S3E5." "Dies in the S4 premiere." Separate row per fact so
// community suggestions can target a specific fact.

model CompanionFact {
  id           String @id @default(cuid())
  characterId  String @map("character_id")
  fact         String @db.Text
  factType     String @map("fact_type") // "role_change" | "relationship_change" | "arc" | "death" | "reveal" | "other"
  visibleAfter Json   @map("visible_after")

  character CompanionCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@map("companion_facts")
}

model CompanionRelationship {
  id               String  @id @default(cuid())
  companionId      String  @map("companion_id")
  seasonNumber     Int?    @map("season_number") // null for movies; required for TV
  fromCharacterId  String  @map("from_character_id")
  toCharacterId    String  @map("to_character_id")
  relationshipType String  @map("relationship_type") // "family" | "romantic" | "business" | "rivalry" | "alliance" | "mentor" | "other"
  label            String // human-readable: "father of", "ex-wife", "reports to", "rival"
  visibleAfter     Json    @map("visible_after")
  directed         Boolean @default(true) // false for symmetric (siblings, allies)

  companion WatchCompanion     @relation(fields: [companionId], references: [id], onDelete: Cascade)
  from      CompanionCharacter @relation("relFrom", fields: [fromCharacterId], references: [id], onDelete: Cascade)
  to        CompanionCharacter @relation("relTo", fields: [toCharacterId], references: [id], onDelete: Cascade)

  @@index([companionId])
  @@index([companionId, seasonNumber])
  @@map("companion_relationships")
}

model CompanionTimelineEvent {
  id           String   @id @default(cuid())
  companionId  String   @map("companion_id")
  seasonNumber Int?     @map("season_number") // null for movies; required for TV
  description  String   @db.Text
  visibleAfter Json     @map("visible_after")
  characterIds String[] @default([]) @map("character_ids") // which characters are involved
  importance   Int      @default(3) // 1-5 — drives filtering ("show only major beats")

  companion WatchCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId])
  @@index([companionId, seasonNumber])
  @@map("companion_timeline_events")
}

model CompanionGlossaryTerm {
  id           String  @id @default(cuid())
  companionId  String  @map("companion_id")
  seasonNumber Int?    @map("season_number") // null for movies; required for TV
  term         String
  definition   String  @db.Text
  visibleAfter Json    @map("visible_after")
  category     String? // "world" | "faction" | "jargon" | "concept"
  sortOrder    Int     @default(0) @map("sort_order") // Claude orders most-obscure-first; preserved at write time

  companion WatchCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId])
  @@index([companionId, seasonNumber])
  @@map("companion_glossary_terms")
}

// User requests for an admin to generate a companion they don't have credits
// for (free users cap at 2/week, Backstage Pass at 5/week). Requests resolve
// in two ways: approved = admin triggers generation; denied = admin rejected
// the ask. When the resulting companion ships to "published", any still-open
// requests targeting that (tmdbId, mediaType, season) get notified.
model CompanionGenerationRequest {
  id           String    @id @default(cuid())
  requesterId  String    @map("requester_id")
  tmdbId       Int       @map("tmdb_id")
  mediaType    String    @map("media_type") // "movie" | "tv"
  season       Int? // null for movies; required for tv
  rationale    String?   @db.Text // optional user note ("why I want this")
  status       String    @default("pending") // "pending" | "approved" | "denied" | "fulfilled"
  resolvedById String?   @map("resolved_by_id")
  resolvedAt   DateTime? @map("resolved_at")
  denyReason   String?   @map("deny_reason") @db.Text
  companionId  String?   @map("companion_id") // set when published so notify step can link to it
  notifiedAt   DateTime? @map("notified_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([tmdbId, mediaType, season])
  @@index([requesterId])
  @@map("companion_generation_requests")
}

// Community-submitted edits. Can be a new item, a correction to an existing
// item, or a deletion request. Payload shape depends on type.

model CompanionSuggestion {
  id          String @id @default(cuid())
  companionId String @map("companion_id")
  submitterId String @map("submitter_id")

  // What kind of change
  action     String // "add" | "edit" | "remove"
  targetType String  @map("target_type") // "character" | "fact" | "relationship" | "timeline" | "glossary" | "baseDescription"
  targetId   String? @map("target_id") // null for "add"; otherwise references the existing row

  // Free-text rationale + structured payload describing the proposed change
  rationale String? @db.Text
  payload   Json // shape depends on targetType

  // Voting + moderation
  status      String @default("pending") // "pending" | "approved" | "dismissed"
  upvoteScore Int    @default(0) @map("upvote_score") // sum of weighted votes (cached)
  voteCount   Int    @default(0) @map("vote_count")

  // Resolution
  resolvedById     String?   @map("resolved_by_id")
  resolvedAt       DateTime? @map("resolved_at")
  resolutionNote   String?   @map("resolution_note") @db.Text
  // When an "add" suggestion is approved, the new row's id is captured here
  // so the viewer can show a "community-sourced" badge on the specific
  // row that came from this suggestion. Null for edits / removes.
  appliedItemId    String?   @map("applied_item_id")
  // Pre-change state of the target, captured at apply-time. For edits:
  // the fields about to be overwritten. For removes: the row's data so an
  // admin can restore it. For adds: null (no prior state). Powers the
  // Revert admin action — critical for undoing troll brigades without
  // losing the original AI content permanently.
  originalSnapshot Json?     @map("original_snapshot")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companion WatchCompanion            @relation(fields: [companionId], references: [id], onDelete: Cascade)
  submitter User                      @relation("suggestionAuthor", fields: [submitterId], references: [id], onDelete: Cascade)
  resolver  User?                     @relation("suggestionResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  votes     CompanionSuggestionVote[]

  @@index([companionId, status])
  @@index([status, createdAt])
  @@map("companion_suggestions")
}

model CompanionSuggestionVote {
  id           String   @id @default(cuid())
  suggestionId String   @map("suggestion_id")
  voterId      String   @map("voter_id")
  vote         Int // +1 or -1
  weight       Int      @default(1) // 1 for regular, 3 for critic (snapshot at vote time)
  createdAt    DateTime @default(now()) @map("created_at")

  suggestion CompanionSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  voter      User                @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, voterId])
  @@map("companion_suggestion_votes")
}

// Mutex preventing concurrent Watch Companion generations on the same
// target (tmdbId, mediaType, season). Two users hitting Generate within
// seconds of each other would otherwise both run all six AI chunks (~2×
// Anthropic spend) and then race in persistDraft's wipe-then-insert
// sequence, producing a mishmash of both runs. The lock acquires at
// stream start, releases on completion or error. Stale locks (>10 min,
// from a crashed gen) are auto-overwritten by the next acquirer rather
// than blocking forever.
//
// Lock key uses season=0 as the sentinel for movies, since a unique
// constraint with NULL would treat each null as distinct in Postgres
// (defeating the purpose).
// User subscription to a "notify when this becomes streaming" alert. A
// daily cron polls TMDB's watch-providers endpoint for each row whose
// notifiedAt is null; once a flatrate (subscription streaming) entry
// appears, it fires a notification and stamps notifiedAt to prevent
// re-firing. Rows aren't deleted on notify so the user can see what
// they were subscribed to in their account history; future re-watches
// would create a new row.
model StreamingWatch {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  tmdbId            Int       @map("tmdb_id")
  mediaType         String    @map("media_type") // "movie" | "tv"
  createdAt         DateTime  @default(now()) @map("created_at")
  // Set when the streaming-availability notification has been delivered.
  // Null = still watching. Non-null = already alerted, treated as
  // resolved so the cron skips it.
  notifiedAt        DateTime? @map("notified_at")
  // Snapshot of the providers that triggered the notification — small
  // diagnostic for the user ("Netflix is now streaming Hoppers!").
  notifiedProviders String?   @map("notified_providers") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId, mediaType])
  @@index([notifiedAt])
  @@index([tmdbId, mediaType])
  @@map("streaming_watches")
}

// Outbound affiliate click tracking. One row per click on a streaming
// provider link (Netflix, Hulu, Prime), Fandango showtimes/tickets,
// Spotify soundtrack, etc. The aggregate report drives partnership
// negotiations — counts per provider per week / month are the leverage
// when approaching companies that don't yet have public affiliate
// programs ("we sent you N clicks last quarter").
//
// Anonymous clicks (logged-out viewers) record userId=null but still
// count toward the aggregate. We don't care who clicked — only how
// often and where.
model AffiliateClick {
  id           String   @id @default(cuid())
  // Stable provider key — name lowercased ("netflix", "hulu", "fandango",
  // "spotify"). Keep this denormalized as a string so a provider's
  // TMDB id can change without breaking historical reports.
  provider     String
  // Full target URL the click sent the user to. Captured for diagnostic
  // verification (did the affiliate ID embed correctly?) and for spot-
  // checks when reviewing the report.
  targetUrl    String   @map("target_url") @db.Text
  userId       String?  @map("user_id")
  // What media the user was clicking FROM, when applicable. Lets the
  // admin see which titles drive the most outbound traffic per provider.
  mediaType    String?  @map("media_type")
  tmdbId       Int?     @map("tmdb_id")
  // Page path the user was on at click time, e.g. "/movies/123".
  referrerPath String?  @map("referrer_path") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

model CompanionGenerationLock {
  id         String   @id @default(cuid())
  tmdbId     Int      @map("tmdb_id")
  mediaType  String   @map("media_type")
  // 0 = movie sentinel, 1+ = TV season number.
  season     Int
  acquiredAt DateTime @default(now()) @map("acquired_at")
  // userId of whoever's generation currently holds the lock — useful for
  // the "another generation is in progress" error message + diagnostics.
  acquiredBy String?  @map("acquired_by")

  @@unique([tmdbId, mediaType, season])
  @@map("companion_generation_locks")
}

// Per-season airing tracker for TV companions whose latest episode is still
// within (last_episode_air_date + 2 days > today). One row per (companion,
// season) the moment the user/admin first triggers generation while that
// season is mid-air. Drives the cron sweep, stores per-episode progress,
// and graduates to status="completed" once all episodes are generated AND
// the recap chunks have run for the season.
model CompanionAiringSeason {
  id                String    @id @default(cuid())
  companionId       String    @map("companion_id")
  seasonNumber      Int       @map("season_number")
  // Episode numbers already generated for this season. Initial gen seeds
  // every episode whose air_date + 2 days <= today; the cron appends as
  // additional episodes pass the buffer. Recap is intentionally NOT stored
  // here — it runs once at finalization, writing into WatchCompanion.recaps.
  episodesGenerated Int[]     @default([]) @map("episodes_generated")
  // "airing" while waiting for more episodes to become eligible;
  // "completed" once last_episode + 2 days has passed AND recap chunks
  // have run AND the season has been pushed into seasonsGenerated.
  status            String    @default("airing")
  // Stamped at the end of each cron pass so admins can see liveness.
  lastSweepAt       DateTime? @map("last_sweep_at")
  // Consecutive cron failures for the next pending episode. Resets on
  // success. Powers the failsafe — after N retries the cron falls back
  // to TMDB-overview-only generation for that episode and resets to 0.
  failureCount      Int       @default(0) @map("failure_count")
  // Last error string captured by the cron, surfaced in admin UI.
  lastError         String?   @map("last_error") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  companion WatchCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@unique([companionId, seasonNumber])
  @@index([status])
  @@map("companion_airing_seasons")
}

// User subscription to a companion. Meaningful while a companion has any
// season in "airing" status — followers receive a notification when each
// new episode's companion is generated. Survives season completion so the
// user can keep the subscription for the next airing season of the same
// show (a follow is per-companion, not per-season).
model CompanionFollow {
  id          String   @id @default(cuid())
  companionId String   @map("companion_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  companion WatchCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companionId, userId])
  @@index([companionId])
  @@index([userId])
  @@map("companion_follows")
}

// Daily snapshot of which streaming providers each item is available on
// per region. Powers the streaming-launches feature on /releases by
// diffing today vs yesterday — providers that appear today but not
// yesterday are "newly on [provider]" events. The cron walks top-N
// popular movies + TV per day, so a single (tmdbId, mediaType, region)
// pair has at most one row per snapshot date.
//
// Storage is bounded by trimming snapshots older than the diff window
// (we only need today + yesterday). Older snapshots are nice-to-have
// for analytics but not load-bearing.
model MediaProviderSnapshot {
  id           String   @id @default(cuid())
  tmdbId       Int      @map("tmdb_id")
  mediaType    String   @map("media_type") // "movie" | "tv"
  region       String // ISO 3166-1 alpha-2 (e.g. "US")
  providerIds  Int[]    @map("provider_ids") // TMDB provider ids the item is on (subscription/free flatrate only — rentals/buys excluded by the cron)
  snapshotDate DateTime @map("snapshot_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tmdbId, mediaType, region, snapshotDate])
  @@index([snapshotDate])
  @@index([tmdbId, mediaType, region])
  @@map("media_provider_snapshots")
}
