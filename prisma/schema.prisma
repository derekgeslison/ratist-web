  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  authorId  String   @map("author_id")
  content   String
  isEdited  Boolean  @default(false) @map("is_edited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("forum_posts")
}

// ─── Community Hub ────────────────────────────────────────────────────────────

// Looks Like
model LooksLike {
  id               String   @id @default(cuid())
  creatorId        String   @map("creator_id")
  tmdbPersonId1    Int      @map("tmdb_person_id_1")
  name1            String
  profilePath1     String?  @map("profile_path_1")
  tmdbPersonId2    Int      @map("tmdb_person_id_2")
  name2            String
  profilePath2     String?  @map("profile_path_2")
  createdAt        DateTime @default(now()) @map("created_at")

  creator User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  votes   LooksLikeVote[]

  @@unique([tmdbPersonId1, tmdbPersonId2])
  @@map("looks_likes")
}

model LooksLikeVote {
  userId      String @map("user_id")
  looksLikeId String @map("looks_like_id")
  value       Int    // 1 = upvote, -1 = downvote

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  looksLike LooksLike @relation(fields: [looksLikeId], references: [id], onDelete: Cascade)

  @@id([userId, looksLikeId])
  @@map("looks_like_votes")
}

// Oscar Picks
model OscarYear {
  id            String    @id @default(cuid())
  year          Int       @unique
  ceremonyDate  DateTime? @map("ceremony_date")
  isComplete    Boolean   @default(false) @map("is_complete") // real ceremony already happened
  createdAt     DateTime  @default(now()) @map("created_at")

  categories OscarCategory[]

  @@map("oscar_years")
}

model OscarCategory {
  id          String @id @default(cuid())
  oscarYearId String @map("oscar_year_id")
  name        String // e.g. "Best Picture"
  slug        String // e.g. "best-picture"
  sortOrder   Int    @default(0) @map("sort_order")

  oscarYear  OscarYear      @relation(fields: [oscarYearId], references: [id], onDelete: Cascade)
  nominees   OscarNominee[]
  votes      OscarVote[]

  @@unique([oscarYearId, slug])
  @@map("oscar_categories")
}

model OscarNominee {
  id             String  @id @default(cuid())
  categoryId     String  @map("category_id")
  tmdbMovieId    Int?    @map("tmdb_movie_id")
  movieTitle     String  @map("movie_title")
  posterPath     String? @map("poster_path")
  nomineeDetail  String? @map("nominee_detail") // e.g. actor name for acting categories
  isWinner       Boolean @default(false) @map("is_winner") // real Oscar winner

  category OscarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes    OscarVote[]

  @@map("oscar_nominees")
}

model OscarVote {
  userId     String @map("user_id")
  categoryId String @map("category_id")
  nomineeId  String @map("nominee_id")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category OscarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nominee  OscarNominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("oscar_votes")
}

// Recast
model Recast {
  id                      String   @id @default(cuid())
  creatorId               String   @map("creator_id")
  tmdbMovieId             Int      @map("tmdb_movie_id")
  movieTitle              String   @map("movie_title")
  posterPath              String?  @map("poster_path")
  characterName           String   @map("character_name")
  originalActorName       String   @map("original_actor_name")
  originalActorTmdbId     Int?     @map("original_actor_tmdb_id")
  suggestedActorName      String   @map("suggested_actor_name")
  suggestedActorTmdbId    Int?     @map("suggested_actor_tmdb_id")
  suggestedActorProfile   String?  @map("suggested_actor_profile")
  createdAt               DateTime @default(now()) @map("created_at")

  creator User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  votes   RecastVote[]

  @@map("recasts")
}

model RecastVote {
  userId   String @map("user_id")
  recastId String @map("recast_id")
  value    Int    // 1 = agree, -1 = disagree

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recast Recast @relation(fields: [recastId], references: [id], onDelete: Cascade)

  @@id([userId, recastId])
  @@map("recast_votes")
}

// Hot Takes
model HotTake {
  id        String   @id @default(cuid())
  authorId  String   @map("author_id")
  content   String   // max 280 chars
  createdAt DateTime @default(now()) @map("created_at")

  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes  HotTakeVote[]

  @@map("hot_takes")
}

model HotTakeVote {
  userId    String @map("user_id")
  hotTakeId String @map("hot_take_id")
  value     Int    // 1 = "hot", -1 = "not"

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotTake HotTake @relation(fields: [hotTakeId], references: [id], onDelete: Cascade)

  @@id([userId, hotTakeId])
  @@map("hot_take_votes")
}

// ─── Cine-Q Quiz ─────────────────────────────────────────────────────────────

model CineQDaily {
  id         String   @id @default(cuid())
  date       String   // "2026-04-06" (Pacific time)
  mediaType  String   @map("media_type")  // "movie" | "tv" | "both"
  difficulty String   // "easy" | "medium" | "hard"
  questions  Json     // array of question objects (title, tmdbId, clues, options)
  createdAt  DateTime @default(now()) @map("created_at")

  attempts CineQAttempt[]

  @@unique([date, mediaType, difficulty])
  @@map("cineq_daily")
}

model CineQAttempt {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  dailyId    String?  @map("daily_id")  // null for practice mode
  mediaType  String   @map("media_type")
  difficulty String
  mode       String   @default("daily") // "daily" | "practice"
  status     String   @default("completed") // "in_progress" | "completed" | "abandoned"
  rawScore   Float    @default(0) @map("raw_score")
  answers    Json?    // array of { questionIndex, correct, timeElapsed, wrongGuesses }
  createdAt  DateTime @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  daily CineQDaily? @relation(fields: [dailyId], references: [id], onDelete: SetNull)

  @@unique([userId, dailyId]) // one attempt per user per daily quiz
  @@map("cineq_attempts")
}

// ─── Movie Club ──────────────────────────────────────────────────────────────

model MovieClubWeek {
  id            String   @id @default(cuid())
  weekNumber    Int      @map("week_number")
  startDate     String   @map("start_date")  // "2026-04-07" Monday
  endDate       String   @map("end_date")    // "2026-04-13" Sunday
  // scheduled → voting (community_vote only, Mon-Tue) → watching (Wed or Mon) → discussion (Fri 8pm ET) → archived (next Mon)
  status        String   @default("scheduled")

  pickMethod    String   @default("random") @map("pick_method") // "admin" | "random" | "community_vote"
  pickFilters   Json?    @map("pick_filters")
  pickTeaser    String?  @map("pick_teaser")

  movieId       String?  @map("movie_id")
  movieTmdbId   Int?     @map("movie_tmdb_id")
  movieTitle    String?  @map("movie_title")
  moviePoster   String?  @map("movie_poster")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  movie         Movie?    @relation(fields: [movieId], references: [id])
  ratings       MovieClubRating[]
  nominations   MovieClubNomination[]

  @@unique([weekNumber])
  @@map("movie_club_weeks")
}

model MovieClubMember {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("movie_club_members")
}

model MovieClubRating {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  weekId       String   @map("week_id")
  rating       Float    // overall 1-10
  reviewText   String?  @db.Text @map("review_text")
  reviewType   String   @default("quick") @map("review_type") // "quick" | "standard"
  isRewatch    Boolean  @default(false) @map("is_rewatch")
  madeOfficial Boolean  @default(false) @map("made_official") // linked to their real Ratist review
  createdAt    DateTime @default(now()) @map("created_at")

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  week MovieClubWeek  @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([userId, weekId])
  @@map("movie_club_ratings")
}

model MovieClubNomination {
  id        String   @id @default(cuid())
  weekId    String   @map("week_id")
  userId    String   @map("user_id")
  tmdbId    Int      @map("tmdb_id")
  title     String
  posterPath String? @map("poster_path")
  createdAt DateTime @default(now()) @map("created_at")

  week  MovieClubWeek          @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes MovieClubNominationVote[]

  @@unique([weekId, tmdbId]) // no duplicate nominations per week
  @@map("movie_club_nominations")
}

model MovieClubNominationVote {
  id           String   @id @default(cuid())
  nominationId String   @map("nomination_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  nomination MovieClubNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nominationId, userId])
  @@map("movie_club_nomination_votes")
}

// Movie/Show Pitches
model MoviePitch {
  id          String   @id @default(cuid())
  authorId    String   @map("author_id")
  title       String   // pitch title (max 100)
  description String   @db.Text // longer description (max 1000)
  mediaType   String   @default("movie") @map("media_type") // "movie" | "tv"
  genre       String?  // optional genre tag
  createdAt   DateTime @default(now()) @map("created_at")

  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes  MoviePitchVote[]

  @@map("movie_pitches")
}

model MoviePitchVote {
  userId  String @map("user_id")
  pitchId String @map("pitch_id")
  value   Int    // 1 = upvote, -1 = downvote

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitch MoviePitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@id([userId, pitchId])
  @@map("movie_pitch_votes")
}

// ─── Screening Room ───────────────────────────────────────────────────────────

enum ScreeningSessionStatus {
  LOBBY
  COUNTDOWN
  WATCHING
  POST_WATCH
  COMPLETE
}

model ScreeningSession {
  id          String                  @id @default(cuid())
  hostId      String                  @map("host_id")
  movieId     String?                 @map("movie_id")
  tmdbId      Int?                    @map("tmdb_id")
  movieTitle  String?                 @map("movie_title")
  posterPath  String?                 @map("poster_path")
  mediaType   String                  @default("movie") @map("media_type")
  status      ScreeningSessionStatus  @default(LOBBY)
  inviteCode  String                  @unique @map("invite_code")
  startedAt   DateTime?               @map("started_at")
  finishedAt  DateTime?               @map("finished_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  host           User                      @relation("screeningHost", fields: [hostId], references: [id], onDelete: Cascade)
  movie          Movie?                    @relation(fields: [movieId], references: [id])
  participants   ScreeningParticipant[]
  predictions    ScreeningPrediction[]
  polls          ScreeningPoll[]
  bookmarks      ScreeningBookmark[]
  chatHighlights ScreeningChatHighlight[]
  ratings        ScreeningRating[]

  @@map("screening_sessions")
}

model ScreeningParticipant {
  sessionId   String   @map("session_id")
  userId      String   @map("user_id")
  joinedAt    DateTime @default(now()) @map("joined_at")
  hasAds      Boolean  @default(false) @map("has_ads")
  hasFinished Boolean  @default(false) @map("has_finished")
  hidden      Boolean  @default(false)

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@map("screening_participants")
}

model ScreeningPrediction {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  userId      String   @map("user_id")
  plotGuess   String?  @map("plot_guess")
  ratingGuess Float?   @map("rating_guess")
  createdAt   DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("screening_predictions")
}

model ScreeningPoll {
  id        String    @id @default(cuid())
  sessionId String    @map("session_id")
  creatorId String    @map("creator_id")
  question  String
  options   Json      // string[]
  votes     Json      @default("{}") // { [userId]: optionIndex }
  revealAt  String    @default("instant") @map("reveal_at") // "instant" | "end"
  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  creator User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("screening_polls")
}

model ScreeningBookmark {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String   @map("user_id")
  timestamp String   // movie timestamp e.g. "01:23:45"
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("screening_bookmarks")
}

model ScreeningChatHighlight {
  id           String   @id @default(cuid())
  sessionId    String   @map("session_id")
  userId       String   @map("user_id")
  text         String
  emoji        String?
  reactCount   Int      @default(0) @map("react_count")  // total messages in this window
  windowGroup  Int      @default(0) @map("window_group") // which burst this belongs to (0, 1, 2)
  timestamp    DateTime
  createdAt    DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("screening_chat_highlights")
}

model ScreeningRating {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  userId    String @map("user_id")

  reviewType String @default("standard") @map("review_type") // "basic" | "standard"

  // Story
  plot               Float?
  premiseOriginality Float? @map("premise_originality")
  storytelling       Float?
  characterDev       Float? @map("character_dev")
  pacingClimax       Float? @map("pacing_climax")

  // Production & Style
  cinematography   Float?
  locationCost     Float? @map("location_costuming")
  realism          Float? @map("realism_believability")
  artisticEffect   Float? @map("artistic_effect")
  visualEffects    Float? @map("visual_effects")
  musicSound       Float? @map("music_sound")

  // Emotive Effect
  overallEmotion Float? @map("overall_emotion")
  relatability   Float?
  meaning        Float?
  movingness     Float?

  // Acting & Casting
  casting            Float?
  actingQuality      Float? @map("acting_quality")
  dialogueScripting  Float? @map("dialogue_scripting")
  blockingChoreo     Float? @map("blocking_choreography")

  // Pure Entertainment
  appeal            Float?
  superficialAllure Float? @map("superficial_allure")
  choreography      Float?

  // Overall
  overallRating Float? @map("overall_rating")

  // Computed
  storyScore     Float? @map("story_score")
  styleScore     Float? @map("style_score")
  emotiveScore   Float? @map("emotive_score")
  actingScore    Float? @map("acting_score")
  entertainScore Float? @map("entertainment_score")
  ratistRating   Float? @map("ratist_rating")

  reviewText String? @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")

  session ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("screening_ratings")
}

model Report {
  id          String   @id @default(cuid())
  targetType  String   @map("target_type") // "review" | "comment" | "forumPost" | "hotTake" | "recast" | "looksLike"
  targetId    String   @map("target_id")
  reporterId  String   @map("reporter_id")
  reason      String   // "spam" | "harassment" | "inappropriate" | "spoilers" | "other"
  details     String?  // optional user-provided detail
  status      String   @default("pending") // "pending" | "dismissed" | "removed" | "warned" | "banned"
  resolvedBy  String?  @map("resolved_by") // admin user ID
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")

  reporter User @relation("reportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("reportsResolved", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@map("reports")
}

model SiteSpotlight {
  id          String   @id @default(cuid())
  title       String
  description String?
  linkUrl     String   @map("link_url")
  linkLabel   String   @default("Read more") @map("link_label")
  imageUrl    String?  @map("image_url")
  type        String   @default("general") // "blog" | "punch_and_judy" | "feature" | "general"
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_spotlights")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  action    String   // "ban" | "unban" | "softDelete" | "restore" | "permanentDelete" | "toggleAdmin" | "removeContent" | "notify" | "resolveReport"
  targetId  String?  @map("target_id")   // user or report ID
  details   String?  // description of what happened
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation("adminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_logs")
}
